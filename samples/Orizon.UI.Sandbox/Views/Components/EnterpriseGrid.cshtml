@{
 ViewData["Title"] = "Orizon Enterprise Grid";
 var products = Enumerable.Range(1, 180).Select(i => new { Id=i, Code=$"PRD-{i:0000}", Description=$"Produto corporativo {i}", Category=new[]{"Software","Serviços","Equipamentos"}[i%3], Price=49.9m+(i*7.35m), Stock=(i*17)%240, Active=i%7!=0 }).ToArray();
 var clients = Enumerable.Range(1, 80).Select(i => new { Id=i, Name=$"Cliente {i:000}", Segment=new[]{"Enterprise","Growth","Starter"}[i%3], City=new[]{"São Paulo","Curitiba","Recife","Belo Horizonte"}[i%4], Revenue=3200m+i*913m, Score=55+(i%45) }).ToArray();
 var orders = Enumerable.Range(1, 120).Select(i => new { Id=i, Number=$"PED-{24000+i}", Customer=$"Conta {i%31:00}", Status=new[]{"Novo","Separação","Faturado","Entregue"}[i%4], Total=780m+i*128.4m, Date=DateTime.Today.AddDays(-i) }).ToArray();
 var treeRows = new[]{new{Id=1,Parent="",Name="Operação",Kind="Área",Owner="Diretoria"},new{Id=2,Parent="Operação",Name="Distribuição",Kind="Unidade",Owner="Marina"},new{Id=3,Parent="Operação",Name="Imobiliário",Kind="Unidade",Owner="Caio"},new{Id=4,Parent="Distribuição",Name="Estoque",Kind="Equipe",Owner="Lia"}};
 var large = Enumerable.Range(1, 10000).Select(i => new { Id=i, Transaction=$"TX-{i:000000}", Account=$"Conta {i%800:000}", Region=new[]{"Sudeste","Sul","Nordeste","Centro-Oeste"}[i%4], Amount=Math.Round(100+(i*19.73m)%25000,2), Quantity=(i*13)%500, Status=i%9==0?"Pendente":"Processado" });
}
<div class="component-catalog">
 <header class="component-catalog__header"><div><h1 class="component-catalog__title">Orizon Enterprise Grid</h1><p class="component-catalog__description">Grade de alta produtividade com virtualização, teclado, seleção e layout persistente, sem dependências externas.</p></div><orizon-button href="/components" variant="outline" color="neutral" text="Voltar" /></header>

 <section class="component-example"><header class="component-example__header"><div><h2>Produtos · Grid completo</h2><p>Ordene, redimensione e reordene colunas; use pesquisa, seletor e menu contextual.</p></div></header><div class="component-example__preview" style="width:100%">
  <orizon-enterprise-grid id="products-grid" items="products" key-field="Id" label="Produtos" virtual-scroll selectable="multiple" persist-key="sandbox-products" height="30rem">
   <orizon-grid-toolbar search add edit delete export refresh><button type="button" data-grid-action="custom">Ação customizada</button></orizon-grid-toolbar>
   <orizon-grid-group-panel /><orizon-grid-column-chooser />
   <orizon-grid-column field="Code" title="Código" width="120" pinned="left" />
   <orizon-grid-column field="Description" title="Descrição" width="280" />
   <orizon-grid-column field="Category" title="Categoria" width="150" />
   <orizon-grid-column field="Price" title="Preço" width="140" format="currency" type="currency" />
   <orizon-grid-column field="Stock" title="Estoque" width="120" format="number" type="number" />
   <orizon-grid-column field="Active" title="Ativo" width="100" format="boolean" />
   <orizon-grid-selection mode="multiple" checkbox cell />
   <orizon-grid-summary-row type="count" label="Produtos" /><orizon-grid-summary-row field="Price" type="average" label="Preço médio" /><orizon-grid-summary-row field="Stock" type="sum" label="Estoque total" />
   <orizon-grid-pager page-size="50" />
   <orizon-grid-filter-panel><p>Filtros por coluna são gerados a partir das definições.</p></orizon-grid-filter-panel>
   <orizon-grid-context-menu><button role="menuitem" type="button">Abrir produto</button><button role="menuitem" type="button">Copiar código</button><button role="menuitem" type="button">Fixar coluna</button></orizon-grid-context-menu>
  </orizon-enterprise-grid>
 </div></section>

 <section class="component-example"><header class="component-example__header"><div><h2>Clientes · Seleção e agrupamento</h2><p>Arraste “Segmento” para o painel de agrupamento ou use seleção múltipla com Shift/Ctrl.</p></div></header><div class="component-example__preview" style="width:100%"><orizon-enterprise-grid id="clients-grid" items="clients" key-field="Id" label="Clientes agrupáveis" height="25rem" selectable="multiple"><orizon-grid-toolbar search export /><orizon-grid-group-panel /><orizon-grid-column field="Name" title="Cliente" width="220" pinned="left" /><orizon-grid-column field="Segment" title="Segmento" width="150" /><orizon-grid-column field="City" title="Cidade" width="170" /><orizon-grid-column field="Revenue" title="Receita" width="150" format="currency" type="currency" /><orizon-grid-column field="Score" title="Score" width="110" type="number" /><orizon-grid-selection mode="multiple" checkbox cell /><orizon-grid-summary-row type="count" label="Clientes" /><orizon-grid-summary-row field="Revenue" type="sum" label="Receita total" /></orizon-enterprise-grid></div></section>

 <section class="component-example"><header class="component-example__header"><div><h2>Pedidos · Paginação e summary</h2><p>Formatação de moeda e data, multi-sort com Shift e tamanhos de página configuráveis.</p></div></header><div class="component-example__preview" style="width:100%"><orizon-enterprise-grid items="orders" key-field="Id" label="Pedidos" height="24rem" virtual-scroll="false"><orizon-grid-toolbar search export /><orizon-grid-column field="Number" title="Pedido" width="130" /><orizon-grid-column field="Customer" title="Cliente" width="190" /><orizon-grid-column field="Status" title="Status" width="140" /><orizon-grid-column field="Total" title="Total" width="150" format="currency" type="currency" /><orizon-grid-column field="Date" title="Data" width="140" format="date" /><orizon-grid-summary-row type="count" label="Pedidos" /><orizon-grid-summary-row field="Total" type="sum" label="Total geral" /><orizon-grid-pager page-size="25" /></orizon-enterprise-grid></div></section>

 <section class="component-example"><header class="component-example__header"><div><h2>Tree Data preparado</h2><p>Campos de identidade e parentesco prontos para evolução da hierarquia.</p></div></header><div class="component-example__preview" style="width:100%"><orizon-enterprise-grid items="treeRows" key-field="Id" label="Estrutura organizacional" height="18rem"><orizon-grid-column field="Name" title="Nome" width="240" /><orizon-grid-column field="Parent" title="Pai" width="180" /><orizon-grid-column field="Kind" title="Tipo" width="140" /><orizon-grid-column field="Owner" title="Responsável" width="180" /></orizon-enterprise-grid></div></section>

 <section class="component-example"><header class="component-example__header"><div><h2>Large Dataset · 10.000 linhas</h2><p>Virtualização incremental: somente as linhas visíveis e uma margem de segurança existem no DOM.</p></div></header><div class="component-example__preview" style="width:100%"><orizon-enterprise-grid id="large-grid" items="large" key-field="Id" label="Dez mil transações" height="34rem" virtual-scroll infinite-scroll persist-key="sandbox-large"><orizon-grid-toolbar search export refresh /><orizon-grid-column-chooser /><orizon-grid-column field="Transaction" title="Transação" width="150" pinned="left" /><orizon-grid-column field="Account" title="Conta" width="150" /><orizon-grid-column field="Region" title="Região" width="150" /><orizon-grid-column field="Amount" title="Valor" width="150" format="currency" type="currency" /><orizon-grid-column field="Quantity" title="Quantidade" width="130" format="number" type="number" /><orizon-grid-column field="Status" title="Status" width="140" /><orizon-grid-selection mode="multiple" cell /><orizon-grid-summary-row type="count" label="Transações" /><orizon-grid-summary-row field="Amount" type="sum" label="Volume" /></orizon-enterprise-grid></div></section>

 <section class="component-example" data-theme="dark" style="padding:1rem;background:var(--orizon-color-background);border-radius:var(--orizon-radius-xl)"><header class="component-example__header"><h2>Tema escuro</h2></header><div class="component-example__preview" style="width:100%"><orizon-enterprise-grid items="products.Take(25)" key-field="Id" label="Produtos em tema escuro" height="20rem"><orizon-grid-toolbar search /><orizon-grid-column field="Code" title="Código" width="130" /><orizon-grid-column field="Description" title="Descrição" width="260" /><orizon-grid-column field="Price" title="Preço" width="140" format="currency" /></orizon-enterprise-grid></div></section>
</div>
