@{
    ViewData["Title"] = "Spinner";
}

<div class="component-catalog">
    <header class="component-catalog__header">
        <div>
            <h1 class="component-catalog__title">Spinner</h1>
            <p class="component-catalog__description">Indicadores de carregamento com role status e rotulo acessivel.</p>
        </div>
        <orizon-button href="/components" variant="secondary" icon="ph ph-arrow-left">Voltar</orizon-button>
    </header>

    <section class="component-example">
        <header class="component-example__header">
            <h2 class="component-example__title">Preview e variacoes</h2>
            <p class="component-example__description">Tamanhos compactos para botoes, cards e paginas.</p>
        </header>
        <div class="component-example__preview">
            <orizon-spinner size="sm" label="Carregando item"></orizon-spinner>
            <orizon-spinner label="Carregando conteudo"></orizon-spinner>
            <orizon-spinner size="lg" label="Carregando pagina"></orizon-spinner>
        </div>
    </section>
</div>
