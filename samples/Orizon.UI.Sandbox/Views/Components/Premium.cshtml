@{ ViewData["Title"] = "Componentes Principais Premium"; }
<div class="component-catalog">
 <header class="component-catalog__header"><div><h1 class="component-catalog__title">Componentes Principais Premium</h1><p class="component-catalog__description">Catálogo central dos componentes premium, seus estados e variantes.</p></div><orizon-button href="/components" variant="outline" color="neutral" icon="arrow-left">Voltar</orizon-button></header>
 <section class="component-example"><header class="component-example__header"><h2>OrizonButton</h2></header><div class="component-example__preview">
 @foreach (var variant in new[] { "solid", "soft", "outline", "ghost", "gradient", "glass", "link" }) { <orizon-button text="@variant" variant="@variant" color="primary" /> }
 @foreach (var color in new[] { "primary", "secondary", "success", "warning", "danger", "info", "neutral" }) { <orizon-button text="@color" variant="soft" color="@color" /> }
 <orizon-button text="Extra small" size="xs" icon="check-circle" /><orizon-button text="Small" size="sm" icon="download" /><orizon-button text="Large" size="lg" icon="floppy-disk" icon-position="end" variant="gradient" /><orizon-button text="Carregando" loading /><orizon-button text="Desabilitado" disabled /><orizon-button text="Largura total" full-width />
 </div></section>
 <section class="component-example"><header class="component-example__header"><h2>OrizonIcon e OrizonIconButton</h2></header><div class="component-example__preview">
 @foreach (var icon in new[] { "house", "bell", "users", "building", "gear", "sun", "moon" }) { <orizon-icon name="@icon" size="24" aria-label="@icon" /> }
 <orizon-icon name="gear" size="32" weight="thin" /><orizon-icon name="gear" size="32" weight="bold" />
 <orizon-icon-button icon="pencil-simple" label="Editar produto" tooltip="Editar produto" /><orizon-icon-button icon="trash" label="Excluir" variant="outline" color="danger" shape="circle" /><orizon-icon-button icon="plus" label="Adicionar" size="sm" /><orizon-icon-button icon="plus" label="Adicionar" size="lg" disabled />
 </div></section>
 <section class="component-example"><header class="component-example__header"><h2>OrizonChip</h2></header><div class="component-example__preview"><orizon-chip text="Em estoque" icon="check-circle" color="success" variant="solid" /><orizon-chip text="Selecionável" color="primary" selectable value="selected" /><orizon-chip text="Removível" color="info" variant="outline" removable /><orizon-chip text="Desabilitado" disabled /></div></section>
 <section class="component-example"><header class="component-example__header"><h2>OrizonSwitch</h2></header><div class="component-example__preview"><orizon-switch name="small" label="Pequeno" size="sm" /><orizon-switch name="normal" label="Produto ativo" description="Disponível nas operações." checked /><orizon-switch name="large" label="Grande" size="lg" color="success" /><orizon-switch name="disabled" label="Desabilitado" checked disabled /></div></section>
 <section class="component-example"><header class="component-example__header"><h2>OrizonAccordion</h2></header><div class="component-example__preview" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(18rem,1fr));width:100%"><orizon-accordion mode="single"><orizon-accordion-item title="Informações fiscais" icon="receipt" expanded>Conteúdo fiscal demonstrativo.</orizon-accordion-item><orizon-accordion-item title="Entrega">Opções de entrega.</orizon-accordion-item><orizon-accordion-item title="Indisponível" disabled>Não disponível.</orizon-accordion-item></orizon-accordion><orizon-accordion mode="multiple"><orizon-accordion-item title="Primeiro" expanded>Painel aberto.</orizon-accordion-item><orizon-accordion-item title="Segundo">Outro painel independente.</orizon-accordion-item></orizon-accordion></div></section>
 <section class="component-example"><header class="component-example__header"><h2>OrizonTooltip</h2></header><div class="component-example__preview">@foreach (var pos in new[] { "top", "right", "bottom", "left" }) { <orizon-tooltip text="Tooltip @pos" position="@pos"><orizon-icon-button icon="info" label="Ajuda: @pos" /></orizon-tooltip> }</div></section>
 <section class="component-example"><header class="component-example__header"><h2>OrizonSkeleton</h2></header><div class="component-example__preview" style="align-items:center;width:100%"><orizon-skeleton variant="text" width="15rem" lines="3" /><orizon-skeleton variant="circle" /><orizon-skeleton variant="rectangle" width="10rem" /><orizon-skeleton variant="card" width="12rem" /><orizon-skeleton variant="table-row" width="15rem" /></div></section>
 <section class="component-example"><header class="component-example__header"><h2>OrizonStatCard</h2></header><div class="component-example__preview" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(15rem,1fr));width:100%"><orizon-stat-card title="Total de vendas" value="R$ 24.780,50" icon="shopping-cart" trend="+12,5%" trend-type="positive" description="Último mês" /><orizon-stat-card title="Custos" value="R$ 8.420" icon="trend-down" trend="-3,2%" trend-type="negative" color="danger" /><orizon-stat-card title="Pedidos" value="284" trend="0%" trend-type="neutral" href="/components/premium" action-label="Ver pedidos" /><orizon-stat-card title="Carregando" value="" loading /></div></section>
</div>
