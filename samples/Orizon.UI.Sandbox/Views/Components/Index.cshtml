@{
    ViewData["Title"] = "Componentes";
}

<div class="component-catalog">
    <header class="component-catalog__header">
        <div>
            <h1 class="component-catalog__title">Componentes</h1>
            <p class="component-catalog__description">
                Catálogo visual dos componentes reutilizáveis disponíveis no Orizon UI.
            </p>
        </div>
    </header>

    <div class="component-catalog__grid">
        <a class="component-catalog-card" href="/components/enterprise-grid">
            <span class="component-catalog-card__icon"><i class="ph ph-grid-nine"></i></span>
            <h2>Enterprise Grid</h2>
            <p>Virtualização, seleção, filtros, agrupamento, colunas, summaries e persistência.</p>
        </a>
        <a class="component-catalog-card" href="/components/templates">
            <span class="component-catalog-card__icon"><i class="ph ph-layout"></i></span>
            <h2>Application Templates</h2>
            <p>Dez aplicações completas que demonstram a composição profissional do Orizon UI.</p>
        </a>
        <a class="component-catalog-card" href="/components/productivity">
            <span class="component-catalog-card__icon"><i class="ph ph-command"></i></span>
            <h2>Productivity Components</h2>
            <p>Comandos, painéis, árvores, timeline, Kanban, atividades e ações rápidas.</p>
        </a>
        <a class="component-catalog-card" href="/components/dashboard">
            <span class="component-catalog-card__icon"><i class="ph ph-chart-line-up"></i></span>
            <h2>Dashboard &amp; Charts</h2>
            <p>Grid, widgets, gráficos SVG, sparklines, rings, gauges, métricas e estados.</p>
        </a>
        <a class="component-catalog-card" href="/components/forms-premium">
            <span class="component-catalog-card__icon"><i class="ph ph-textbox"></i></span>
            <h2>Advanced Forms</h2>
            <p>Vinte campos premium com binding, validação, máscaras, seleção e uploads.</p>
        </a>
        <a class="component-catalog-card" href="/components/data">
            <span class="component-catalog-card__icon"><i class="ph ph-table"></i></span>
            <h2>Data Components</h2>
            <p>Toolbar, pesquisa, filtros, DataTable, overlays, confirmações, notificações e KPIs.</p>
        </a>
        <a class="component-catalog-card" href="/components/premium">
            <span class="component-catalog-card__icon"><i class="ph ph-sparkle"></i></span>
            <h2>Componentes Premium</h2>
            <p>Buttons, icons, chips, switches, accordion, tooltips, skeletons e stat cards.</p>
        </a>
        <a class="component-catalog-card" href="/components/design-language">
            <span class="component-catalog-card__icon"><i class="ph ph-palette"></i></span>
            <h2>Orizon Design Language</h2>
            <p>Tokens, temas, tipografia, espacamento, elevacao e identidade oficial.</p>
        </a>
        <a class="component-catalog-card" href="/components/appearance">
            <span class="component-catalog-card__icon"><i class="ph ph-paint-brush"></i></span>
            <h2>Theme Manager</h2>
            <p>Personalizacao, preview em tempo real e preferencias de interface.</p>
        </a>
        <a class="component-catalog-card"
           asp-controller="Components"
           asp-action="Buttons">
            <span class="component-catalog-card__icon">
                <i class="ph ph-cursor-click"></i>
            </span>

            <h2>Buttons</h2>
            <p>Variantes, tamanhos, ícones e estados de carregamento.</p>
        </a>

        <a class="component-catalog-card"
           asp-controller="Components"
           asp-action="Cards">
            <span class="component-catalog-card__icon">
                <i class="ph ph-cards"></i>
            </span>

            <h2>Cards</h2>
            <p>Containers reutilizáveis para conteúdos e indicadores.</p>
        </a>

        <a class="component-catalog-card"
           asp-controller="Components"
           asp-action="Alerts">
            <span class="component-catalog-card__icon">
                <i class="ph ph-warning-circle"></i>
            </span>

            <h2>Alerts</h2>
            <p>Mensagens de informação, sucesso, atenção e erro.</p>
        </a>

        <a class="component-catalog-card"
           asp-controller="Components"
           asp-action="Badges">
            <span class="component-catalog-card__icon">
                <i class="ph ph-tag"></i>
            </span>

            <h2>Badges</h2>
            <p>Status, categorias e indicadores compactos.</p>
        </a>

        <a class="component-catalog-card"
           asp-controller="Components"
           asp-action="Forms">
            <span class="component-catalog-card__icon">
                <i class="ph ph-textbox"></i>
            </span>

            <h2>Forms</h2>
            <p>Inputs, selects, textareas, ajuda, erro e estados de campo.</p>
        </a>

        <a class="component-catalog-card"
           asp-controller="Components"
           asp-action="Tables">
            <span class="component-catalog-card__icon">
                <i class="ph ph-table"></i>
            </span>

            <h2>Tables</h2>
            <p>Tabelas responsivas para status, valores e acoes.</p>
        </a>

        <a class="component-catalog-card" href="/components/modal">
            <span class="component-catalog-card__icon"><i class="ph ph-square-half"></i></span>
            <h2>Modal</h2>
            <p>Dialogos acessiveis com foco gerenciado e fechamento por Escape.</p>
        </a>

        <a class="component-catalog-card" href="/components/dropdown">
            <span class="component-catalog-card__icon"><i class="ph ph-list"></i></span>
            <h2>Dropdown</h2>
            <p>Menus acionaveis por teclado, clique e foco.</p>
        </a>

        <a class="component-catalog-card" href="/components/tabs">
            <span class="component-catalog-card__icon"><i class="ph ph-tabs"></i></span>
            <h2>Tabs</h2>
            <p>Navegacao por abas com ARIA e setas do teclado.</p>
        </a>

        <a class="component-catalog-card" href="/components/pagination">
            <span class="component-catalog-card__icon"><i class="ph ph-caret-double-right"></i></span>
            <h2>Pagination</h2>
            <p>Controles de paginacao responsivos e semanticos.</p>
        </a>

        <a class="component-catalog-card" href="/components/avatar">
            <span class="component-catalog-card__icon"><i class="ph ph-user-circle"></i></span>
            <h2>Avatar</h2>
            <p>Identidade visual com iniciais, imagem, tamanhos e status.</p>
        </a>

        <a class="component-catalog-card" href="/components/toast">
            <span class="component-catalog-card__icon"><i class="ph ph-bell-ringing"></i></span>
            <h2>Toast</h2>
            <p>Feedback nao bloqueante com regioes live e dispensavel.</p>
        </a>

        <a class="component-catalog-card" href="/components/progress">
            <span class="component-catalog-card__icon"><i class="ph ph-chart-bar"></i></span>
            <h2>Progress</h2>
            <p>Barras de progresso com valor acessivel.</p>
        </a>

        <a class="component-catalog-card" href="/components/spinner">
            <span class="component-catalog-card__icon"><i class="ph ph-circle-notch"></i></span>
            <h2>Spinner</h2>
            <p>Indicadores de carregamento compactos.</p>
        </a>

        <a class="component-catalog-card" href="/components/empty-state">
            <span class="component-catalog-card__icon"><i class="ph ph-tray"></i></span>
            <h2>Empty State</h2>
            <p>Estados vazios com mensagem, icone e acao.</p>
        </a>
    </div>
</div>
