@model StudioPageViewModel
@{ ViewData["Title"] = "Playground"; ViewData["ApplicationName"] = "Orizon Studio"; }
@section Styles { <link rel="stylesheet" href="~/css/studio.css" asp-append-version="true" /> }
<main class="studio" data-studio-page data-button-playground>
    <partial name="_StudioHeader" model="Model" />
    <section class="studio-builder-intro"><div><span class="studio-kicker">Interactive workspace</span><h2>Construa seu Button</h2><p>Ajuste a API pública e veja o componente real responder imediatamente.</p></div><div class="studio-viewport-switcher" data-viewport-controls><button type="button" class="is-active" data-viewport="desktop" aria-label="Desktop"><orizon-icon name="desktop" size="17" /></button><button type="button" data-viewport="tablet" aria-label="Tablet"><orizon-icon name="tablet" size="17" /></button><button type="button" data-viewport="mobile" aria-label="Mobile"><orizon-icon name="mobile" size="17" /></button></div></section>
    <div class="studio-builder">
        <aside class="studio-controls"><header><span>01</span><div><h3>Propriedades</h3><p>Button</p></div></header><div class="studio-fields">
            <label>Text<input type="text" value="Salvar alterações" data-button-control="text" /></label>
            <div class="studio-field-row"><label>Variant<select data-button-control="variant"><option>solid</option><option>soft</option><option>outline</option><option>ghost</option><option>gradient</option><option>glass</option><option>link</option></select></label><label>Size<select data-button-control="size"><option>xs</option><option>sm</option><option selected>md</option><option>lg</option></select></label></div>
            <label>Icon<select data-button-control="icon"><option value="">Sem ícone</option><option value="save">save</option><option value="plus">plus</option><option value="check">check</option><option value="download">download</option></select></label>
            <div class="studio-switches"><label><span>Disabled<small>Bloqueia interação</small></span><input type="checkbox" data-button-control="disabled" /></label><label><span>Loading<small>Exibe processamento</small></span><input type="checkbox" data-button-control="loading" /></label><label><span>Rounded<small>Formato pill</small></span><input type="checkbox" data-button-control="rounded" /></label><label><span>Full Width<small>Ocupa o container</small></span><input type="checkbox" data-button-control="fullWidth" /></label></div>
        </div></aside>
        <section class="studio-live-preview"><header><span>02</span><div><h3>Preview</h3><p>Atualização em tempo real</p></div><i class="studio-live-dot">Live</i></header><div class="studio-preview-shell" data-preview-shell data-size="desktop"><div class="studio-button-stage"><button type="button" class="orizon-button orizon-button--solid orizon-button--primary orizon-button--md" data-button-preview><span class="orizon-button__content">Salvar alterações</span></button></div></div></section>
        <aside class="studio-generated-code" data-generated-panel><header><span>03</span><div><h3>Code</h3><p>Pronto para copiar</p></div></header><div class="studio-code__tabs" role="tablist"><button type="button" class="is-active" data-generated-tab="razor">Razor</button><button type="button" data-generated-tab="html">HTML</button><button type="button" data-generated-tab="css">CSS</button><button type="button" data-generated-tab="csharp">C#</button></div><pre><code data-generated-output></code></pre><button type="button" class="studio-copy studio-copy--wide" data-copy-generated><orizon-icon name="copy" size="16" /><span>Copy Razor</span></button><p class="studio-copy-status" aria-live="polite"></p></aside>
    </div>
</main>
@section Scripts { <script src="~/js/studio.js" asp-append-version="true"></script> }
