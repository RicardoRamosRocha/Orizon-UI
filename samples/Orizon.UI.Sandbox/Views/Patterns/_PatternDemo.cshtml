@model PatternPageViewModel

@switch (Model.Slug)
{
    case "crud":
        <div data-demo="crud">
            <orizon-command-bar title="Clientes" subtitle="3 registros" breadcrumb="CRM / Clientes" primary-text="Novo cliente" />
            <orizon-toolbar label="Ações da lista"><div data-toolbar-group><orizon-button text="Editar" icon="edit" variant="outline" /><button type="button" class="orizon-button orizon-button--outline orizon-button--danger" data-demo-confirm>Excluir</button></div><div data-toolbar-right><orizon-search-box placeholder="Pesquisar cliente" full-width /></div></orizon-toolbar>
            <orizon-filter-bar count="1"><orizon-chip text="Status: ativo" color="success" selected removable /><label class="patterns-inline-select">Segmento <select data-demo-filter><option value="">Todos</option><option>Enterprise</option><option>Growth</option></select></label></orizon-filter-bar>
            <orizon-data-table label="Clientes cadastrados" striped hover selectable pageable page="1" total-pages="3"><thead><tr><th>Cliente</th><th>Segmento</th><th>Status</th><th>Receita</th></tr></thead><tbody><tr data-demo-row="Acme Brasil Enterprise"><td><button type="button" class="patterns-link-button" data-demo-edit>Acme Brasil</button></td><td>Enterprise</td><td><orizon-chip text="Ativo" color="success" size="sm" /></td><td>R$ 48.200</td></tr><tr data-demo-row="Aurora Labs Growth"><td>Aurora Labs</td><td>Growth</td><td><orizon-chip text="Trial" color="warning" size="sm" /></td><td>R$ 8.900</td></tr><tr data-demo-row="Horizonte Enterprise"><td>Grupo Horizonte</td><td>Enterprise</td><td><orizon-chip text="Ativo" color="success" size="sm" /></td><td>R$ 72.400</td></tr></tbody></orizon-data-table>
            <div class="patterns-dialog" role="dialog" aria-modal="true" aria-labelledby="crud-dialog-title" hidden data-demo-dialog><div><h3 id="crud-dialog-title">Editar cliente</h3><orizon-text-box name="CrudName" label="Nome" value="Acme Brasil" /><div class="patterns-actions"><button type="button" class="orizon-button orizon-button--outline orizon-button--neutral" data-demo-close>Cancelar</button><orizon-button text="Salvar" data-demo-save /></div></div></div>
            <orizon-confirm-dialog id="pattern-crud-delete" title="Excluir cliente?" message="Esta ação será registrada no histórico." type="danger" confirm-text="Excluir" />
        </div>
        break;
    case "dashboard":
        <div data-demo="dashboard"><orizon-command-bar title="Visão executiva" subtitle="Atualizado agora" breadcrumb="Operações / Hoje" primary-text="Criar relatório" /><orizon-dashboard-grid columns="12" responsive><orizon-metric-card title="Receita" value="R$ 1,24 mi" variation="+12,8%" trend="positive" sparkline="[42,48,46,57,62,68]" /><orizon-metric-card title="Conversão" value="8,4%" variation="+0,9 p.p." trend="positive" /><orizon-metric-card title="SLA" value="96,2%" variation="-1,1 p.p." trend="negative" /></orizon-dashboard-grid><div class="patterns-two-columns"><orizon-dashboard-widget title="Receita por semana" subtitle="Realizado versus meta"><orizon-chart type="line" labels='["S1","S2","S3","S4"]' series='[{"name":"Realizado","data":[72,84,81,96]},{"name":"Meta","data":[75,80,85,90]}]' height="260" legend tooltip grid axis /></orizon-dashboard-widget><orizon-quick-actions label="Ações rápidas" columns="2"><div data-quick-action="report"><span data-quick-icon>▥</span><button type="button" class="patterns-action-tile" data-demo-action="Relatório aberto"><strong>Relatório</strong><small>Detalhar KPIs</small></button></div><div data-quick-action="team"><span data-quick-icon>◎</span><button type="button" class="patterns-action-tile" data-demo-action="Equipe consultada"><strong>Equipe</strong><small>Ver responsáveis</small></button></div></orizon-quick-actions></div><orizon-activity-feed label="Atividade recente"><section data-activity-group><h3>Hoje</h3><article data-activity-item><span data-activity-avatar>MF</span><div><p>Marina atualizou a meta comercial.</p><time>há 12 min</time></div></article><article data-activity-item><span data-activity-avatar>CA</span><div><p>Caio concluiu a revisão de SLA.</p><time>há 38 min</time></div></article></section></orizon-activity-feed></div>
        break;
    case "login":
        <div class="patterns-auth" data-demo="login"><orizon-card title="Acesse sua conta" subtitle="Use seu e-mail corporativo"><div class="patterns-auth-tabs" role="tablist" aria-label="Fluxos de acesso"><button type="button" role="tab" aria-selected="true" data-auth-tab="login">Login</button><button type="button" role="tab" aria-selected="false" tabindex="-1" data-auth-tab="forgot">Esqueci a senha</button><button type="button" role="tab" aria-selected="false" tabindex="-1" data-auth-tab="reset">Redefinir</button><button type="button" role="tab" aria-selected="false" tabindex="-1" data-auth-tab="mfa">MFA</button></div><form data-auth-panel="login"><orizon-email name="LoginEmail" label="E-mail" required /><orizon-password name="LoginPassword" label="Senha" required /><orizon-button type="submit" text="Entrar" /></form><form data-auth-panel="forgot" hidden><orizon-email name="RecoveryEmail" label="E-mail da conta" required /><orizon-button type="submit" text="Enviar link" /></form><form data-auth-panel="reset" hidden><orizon-password name="NewPassword" label="Nova senha" strength required /><orizon-button type="submit" text="Redefinir senha" /></form><form data-auth-panel="mfa" hidden><orizon-text-box name="MfaCode" label="Código de 6 dígitos" maxlength="6" inputmode="numeric" required /><orizon-button type="submit" text="Confirmar acesso" /></form></orizon-card><orizon-alert variant="warning" title="Sessão expirada">Entre novamente para continuar de onde parou.</orizon-alert></div>
        break;
    case "wizard":
        <div data-demo="wizard"><div class="patterns-stepper" role="list" aria-label="Progresso"><span class="is-current" role="listitem">1. Conta</span><span role="listitem">2. Empresa</span><span role="listitem">3. Revisão</span><span role="listitem">4. Confirmação</span></div><orizon-progress value="25" label="Etapa 1 de 4" data-wizard-progress /><form class="patterns-wizard-form"><section data-wizard-step="0"><h3>Dados da conta</h3><orizon-email name="WizardEmail" label="E-mail" required /></section><section data-wizard-step="1" hidden><h3>Dados da empresa</h3><orizon-text-box name="CompanyName" label="Razão social" required /><orizon-select name="CompanySize" label="Porte"><option>Até 50 pessoas</option><option>51 a 500 pessoas</option></orizon-select></section><section data-wizard-step="2" hidden><h3>Revise as informações</h3><orizon-alert variant="info" title="Antes de confirmar">Verifique os dados informados nas etapas anteriores.</orizon-alert></section><section data-wizard-step="3" hidden><orizon-empty-state title="Cadastro confirmado" description="O workspace está pronto para uso." icon="check" /></section><div class="patterns-actions"><button type="button" class="orizon-button orizon-button--outline orizon-button--neutral" data-wizard-back disabled>Voltar</button><orizon-button type="button" text="Avançar" data-wizard-next /></div></form></div>
        break;
    case "search":
        <div data-demo="search"><orizon-command-bar title="Catálogo de contratos" subtitle="4 resultados" breadcrumb="Jurídico / Busca" /><div class="patterns-search-controls"><orizon-search-box placeholder="Empresa ou contrato" shortcut full-width /><label>Ordenar<select data-search-sort><option value="name">Nome</option><option value="value">Maior valor</option></select></label></div><orizon-filter-bar count="2"><button type="button" class="patterns-chip is-active" data-quick-filter="">Todos</button><button type="button" class="patterns-chip" data-quick-filter="Ativo">Ativos</button><button type="button" class="patterns-chip" data-quick-filter="Revisão">Em revisão</button><orizon-chip text="2026" color="primary" selected removable /></orizon-filter-bar><div class="patterns-results" data-search-results><button type="button" data-search-item="Acme Ativo" data-value="92000"><strong>Acme Brasil</strong><span>Ativo · R$ 92.000</span></button><button type="button" data-search-item="Aurora Revisão" data-value="48000"><strong>Aurora Labs</strong><span>Revisão · R$ 48.000</span></button><button type="button" data-search-item="Horizonte Ativo" data-value="125000"><strong>Grupo Horizonte</strong><span>Ativo · R$ 125.000</span></button></div><div data-search-empty hidden><orizon-empty-state title="Nenhum contrato encontrado" description="Remova filtros ou tente outro termo." icon="search" /></div></div>
        break;
    case "master-detail":
        <div data-demo="master-detail"><orizon-command-bar title="Contas estratégicas" subtitle="Selecione uma conta" breadcrumb="CRM / Carteira" /><div class="patterns-master-detail"><nav aria-label="Contas"><button type="button" class="is-active" data-master-item data-name="Acme Brasil" data-segment="Enterprise">Acme Brasil <small>Enterprise</small></button><button type="button" data-master-item data-name="Aurora Labs" data-segment="Growth">Aurora Labs <small>Growth</small></button><button type="button" data-master-item data-name="Grupo Horizonte" data-segment="Enterprise">Grupo Horizonte <small>Enterprise</small></button></nav><section aria-live="polite"><h3 data-detail-name>Acme Brasil</h3><orizon-chip text="Ativo" color="success" /><p>Segmento: <strong data-detail-segment>Enterprise</strong></p><div class="patterns-auth-tabs" role="tablist" aria-label="Detalhes"><button type="button" role="tab" aria-selected="true" data-detail-tab="overview">Resumo</button><button type="button" role="tab" aria-selected="false" data-detail-tab="timeline">Timeline</button><button type="button" role="tab" aria-selected="false" data-detail-tab="comments">Comments</button><button type="button" role="tab" aria-selected="false" data-detail-tab="history">History</button></div><div data-detail-panel="overview"><orizon-card title="Relacionamento" subtitle="Renovação em 42 dias">Receita anual: <strong>R$ 580 mil</strong></orizon-card></div><div data-detail-panel="timeline" hidden><orizon-timeline label="Timeline da conta"><article data-timeline-item><time>18 jul</time><h4>Reunião executiva</h4><p>Próximos passos alinhados.</p></article></orizon-timeline></div><div data-detail-panel="comments" hidden><orizon-textarea name="DetailComment" label="Novo comentário" rows="3" /><orizon-button text="Comentar" data-demo-action="Comentário adicionado" /></div><div data-detail-panel="history" hidden><p>Última atualização: hoje, 09:42 por Marina.</p></div></section></div></div>
        break;
    case "data-entry":
        <form data-demo="data-entry" class="patterns-data-entry"><div class="patterns-autosave"><span aria-hidden="true"></span><strong data-autosave-status>Rascunho salvo</strong></div><orizon-accordion single><orizon-accordion-item title="Identificação" open><div class="patterns-form-grid"><orizon-text-box name="LegalName" label="Razão social" required /><orizon-cnpj name="CompanyDocument" label="CNPJ" required /><orizon-email name="ContactEmail" label="E-mail" required /><orizon-select name="Category" label="Categoria"><option>Fornecedor</option><option>Cliente</option></orizon-select></div></orizon-accordion-item><orizon-accordion-item title="Documentos"><orizon-drag-drop-upload name="Documents" label="Anexos" accept=".pdf,.png,.jpg" multiple /></orizon-accordion-item><orizon-accordion-item title="Observações"><orizon-textarea name="Notes" label="Contexto adicional" rows="4" /></orizon-accordion-item></orizon-accordion><orizon-alert variant="danger" title="Validação" hidden data-entry-error>Preencha os campos obrigatórios antes de enviar.</orizon-alert><div class="patterns-actions"><orizon-button type="button" text="Salvar rascunho" variant="outline" data-demo-action="Rascunho salvo" /><orizon-button type="submit" text="Enviar cadastro" /></div></form>
        break;
    case "approval-workflow":
        <div data-demo="approval"><orizon-command-bar title="Solicitação #4821" subtitle="Aguardando sua decisão" breadcrumb="Financeiro / Aprovações" /><div class="patterns-two-columns"><orizon-card title="Aumento de limite" subtitle="Solicitado por Marina Costa"><p>De <strong>R$ 80 mil</strong> para <strong>R$ 120 mil</strong>.</p><orizon-badge variant="warning">Pendente</orizon-badge><orizon-textarea name="ApprovalComment" label="Comentário da decisão" rows="3" /><div class="patterns-actions"><button type="button" class="orizon-button orizon-button--outline orizon-button--danger" data-approval="Rejeitada">Rejeitar</button><orizon-button text="Aprovar" data-approval="Aprovada" /></div></orizon-card><orizon-timeline label="Histórico e auditoria" data-approval-timeline><article data-timeline-item><time>Hoje, 09:30</time><h4>Solicitação criada</h4><p>Marina Costa · IP registrado</p></article><article data-timeline-item><time>Hoje, 10:12</time><h4>Análise financeira concluída</h4><p>Risco dentro da política.</p></article></orizon-timeline></div></div>
        break;
    case "kanban":
        <div data-demo="kanban"><orizon-command-bar title="Roadmap do produto" subtitle="Sprint 28" breadcrumb="Produto / Kanban" primary-text="Nova tarefa" /><orizon-filter-bar count="1"><button type="button" class="patterns-chip is-active" data-kanban-filter="">Todos</button><button type="button" class="patterns-chip" data-kanban-filter="high">Alta prioridade</button></orizon-filter-bar><orizon-kanban label="Roadmap" draggable persist-key="patterns-kanban"><section data-kanban-column data-column-id="todo"><header><h3>A fazer</h3><span>2</span></header><div data-kanban-list><article draggable="true" tabindex="0" data-kanban-card data-card-id="billing" data-priority="high"><orizon-badge variant="danger">Alta</orizon-badge><h4>Revisar cobrança</h4><p>Marina · Hoje</p></article><article draggable="true" tabindex="0" data-kanban-card data-card-id="audit" data-priority="normal"><h4>Auditoria de acesso</h4><p>Caio · Amanhã</p></article></div></section><section data-kanban-column data-column-id="doing"><header><h3>Em andamento</h3><span>1</span></header><div data-kanban-list><article draggable="true" tabindex="0" data-kanban-card data-card-id="portal" data-priority="high"><orizon-badge variant="danger">Alta</orizon-badge><h4>Novo portal</h4><p>Lia · Sex</p></article></div></section><section data-kanban-column data-column-id="done"><header><h3>Concluído</h3><span>1</span></header><div data-kanban-list><article draggable="true" tabindex="0" data-kanban-card data-card-id="tokens" data-priority="normal"><h4>Revisar tokens</h4><p>Design · Ontem</p></article></div></section></orizon-kanban><orizon-timeline label="Timeline"><article data-timeline-item><time>há 14 min</time><h4>Prioridade alterada</h4><p>Marina marcou “Revisar cobrança” como alta.</p></article></orizon-timeline></div>
        break;
    case "analytics":
        <div data-demo="analytics"><orizon-command-bar title="Performance comercial" subtitle="Atualizado há 5 minutos" breadcrumb="Analytics / Receita" primary-text="Exportar" /><div class="patterns-search-controls"><label>Período<select data-analytics-period><option value="6">Últimos 6 meses</option><option value="12">Últimos 12 meses</option></select></label><label>Comparar com<select><option>Período anterior</option><option>Meta anual</option></select></label></div><orizon-dashboard-grid columns="12" responsive><orizon-metric-card title="ARR" value="R$ 5,14 mi" variation="+18,2%" trend="positive" /><orizon-metric-card title="Retenção" value="92,4%" variation="+1,8 p.p." trend="positive" /><orizon-metric-card title="CAC" value="R$ 384" variation="-7,2%" trend="positive" /></orizon-dashboard-grid><orizon-dashboard-widget title="Receita por período" subtitle="Clique em uma barra para detalhar"><orizon-chart type="bar" labels='["Fev","Mar","Abr","Mai","Jun","Jul"]' series='[{"name":"Receita","data":[610,680,720,790,850,920]}]' height="280" tooltip grid axis /></orizon-dashboard-widget><button type="button" class="orizon-button orizon-button--outline orizon-button--neutral" data-analytics-drill>Drill down: segmentos</button><div data-analytics-detail hidden><orizon-data-table label="Receita por segmento" striped><thead><tr><th>Segmento</th><th>Receita</th><th>Variação</th></tr></thead><tbody><tr><td>Enterprise</td><td>R$ 2,67 mi</td><td>+21%</td></tr><tr><td>Growth</td><td>R$ 1,59 mi</td><td>+14%</td></tr></tbody></orizon-data-table></div></div>
        break;
}
