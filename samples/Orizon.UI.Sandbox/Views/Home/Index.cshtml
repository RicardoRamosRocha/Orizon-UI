                                    <div class="activity-card">

                                        <h4>

                                            Recent Activity

                                        </h4>

                                        <ul>

                                            <li>
                                                <span class="dot green"></span>
                                                User created
                                            </li>

                                            <li>
                                                <span class="dot blue"></span>
                                                Product updated
                                            </li>

                                            <li>
                                                <span class="dot orange"></span>
                                                Price changed
                                            </li>

                                            <li>
                                                <span class="dot purple"></span>
