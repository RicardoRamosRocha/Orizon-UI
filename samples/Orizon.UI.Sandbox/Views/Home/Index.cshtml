@{
    ViewData["Title"] = "Orizon UI — Enterprise Design System";
    ViewData["ApplicationName"] = "Orizon UI";
}

@section Styles {
    <link rel="stylesheet" href="~/css/showcase.css" asp-append-version="true" />
}

<main class="showcase">
    <!-- Hero -->
    <section class="showcase-hero" aria-labelledby="showcase-title">
        <div class="hero-glow hero-glow--one" aria-hidden="true"></div>
        <div class="hero-glow hero-glow--two" aria-hidden="true"></div>
        <div class="hero-copy">
            <span class="eyebrow"><span></span> Enterprise UI for .NET 8</span>
            <h1 id="showcase-title">Build serious software.<br /><em>Ship it beautifully.</em></h1>
            <p class="hero-lead">A complete Design System for ASP.NET Core MVC.</p>
            <p class="hero-description">Create sophisticated dashboards, internal tools and mission-critical products with production-ready components, precise design tokens and enterprise-grade foundations.</p>
            <div class="hero-actions">
                <a class="showcase-button showcase-button--primary" href="/components">Explore components <span aria-hidden="true">→</span></a>
                <a class="showcase-button showcase-button--secondary" href="/grid">See Enterprise Grid</a>
            </div>
            <div class="hero-trust"><span class="trust-avatars" aria-hidden="true"><i>O</i><i>UI</i><i>8</i></span><span>Built for teams that value speed,<br />consistency and craft.</span></div>
        </div>

        <div class="product-preview" aria-label="Orizon UI analytics dashboard preview">
            <div class="preview-bar"><span class="preview-dots"><i></i><i></i><i></i></span><span>orizon.app / overview</span><span class="preview-live"><i></i> Live</span></div>
            <div class="preview-shell">
                <aside class="preview-nav" aria-hidden="true"><b>O</b><i class="is-active"></i><i></i><i></i><i></i><i></i><span></span><i></i></aside>
                <div class="preview-main">
                    <div class="preview-heading"><div><small>OVERVIEW</small><strong>Good morning, Alex</strong></div><span class="preview-avatar">AM</span></div>
                    <div class="preview-kpis">
                        <article><small>Revenue</small><strong>$84.2k</strong><span>↗ 12.4%</span></article>
                        <article><small>New orders</small><strong>1,429</strong><span>↗ 8.1%</span></article>
                        <article><small>Conversion</small><strong>24.8%</strong><span>↗ 3.2%</span></article>
                    </div>
                    <div class="preview-panels">
                        <article class="preview-chart"><header><div><small>PERFORMANCE</small><strong>Revenue overview</strong></div><span>Last 6 months⌄</span></header><div class="chart-area"><svg viewBox="0 0 500 180" role="img" aria-label="Revenue trending upward"><defs><linearGradient id="chart-fill" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="currentColor" stop-opacity=".24"/><stop offset="1" stop-color="currentColor" stop-opacity="0"/></linearGradient></defs><path class="chart-fill" d="M0 150 C60 145 65 105 120 115 S190 75 245 90 S330 35 385 55 S445 22 500 18 L500 180 L0 180Z"/><path class="chart-line" d="M0 150 C60 145 65 105 120 115 S190 75 245 90 S330 35 385 55 S445 22 500 18"/></svg><div class="chart-labels"><span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span><span>May</span><span>Jun</span></div></div></article>
                        <article class="preview-activity"><header><small>ACTIVITY</small><strong>Recent events</strong></header><ul><li><i class="activity-icon">✓</i><span><b>Payment received</b><small>2 min ago</small></span><strong>+$4,250</strong></li><li><i class="activity-icon activity-icon--violet">+</i><span><b>New customer</b><small>18 min ago</small></span></li><li><i class="activity-icon activity-icon--orange">↗</i><span><b>Report exported</b><small>1 hour ago</small></span></li></ul></article>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- KPIs -->
    <section class="metrics" aria-label="Orizon UI product metrics">
        <article><strong>320<span>+</span></strong><small>Components</small></article>
        <article><strong>160<span>+</span></strong><small>Icons</small></article>
        <article><strong>9</strong><small>Themes</small></article>
        <article><strong>.NET 8</strong><small>Native</small></article>
        <article><strong>MVC</strong><small>First</small></article>
        <article><strong><span class="metric-moon">◐</span></strong><small>Dark Mode</small></article>
    </section>

    <!-- Component categories -->
    <section class="showcase-section categories" aria-labelledby="categories-title">
        <header class="section-heading"><span class="eyebrow">The complete toolkit</span><h2 id="categories-title">One system. Every interface.</h2><p>Purpose-built building blocks that stay consistent from the first form to the most complex data experience.</p></header>
        <div class="category-grid">
            <a class="category-card" href="/components"><span class="category-icon icon-foundations" aria-hidden="true">✦</span><div><h3>Foundations</h3><p>Tokens, color, type and spacing.</p></div><i>→</i></a>
            <a class="category-card" href="/components"><span class="category-icon icon-layout" aria-hidden="true">▦</span><div><h3>Layout</h3><p>Responsive structure and composition.</p></div><i>→</i></a>
            <a class="category-card" href="/components/forms"><span class="category-icon icon-forms" aria-hidden="true">⌁</span><div><h3>Forms</h3><p>Accessible inputs and validation.</p></div><i>→</i></a>
            <a class="category-card" href="/components"><span class="category-icon icon-navigation" aria-hidden="true">⌘</span><div><h3>Navigation</h3><p>Wayfinding for complex products.</p></div><i>→</i></a>
            <a class="category-card" href="/components"><span class="category-icon icon-data" aria-hidden="true">◫</span><div><h3>Data</h3><p>Tables, lists and visualization.</p></div><i>→</i></a>
            <a class="category-card" href="/components"><span class="category-icon icon-feedback" aria-hidden="true">◉</span><div><h3>Feedback</h3><p>Clear states, alerts and progress.</p></div><i>→</i></a>
            <a class="category-card" href="/grid"><span class="category-icon icon-grid" aria-hidden="true">▤</span><div><h3>Grid</h3><p>Enterprise data at any scale.</p></div><i>→</i></a>
            <a class="category-card" href="/components"><span class="category-icon icon-charts" aria-hidden="true">⌁</span><div><h3>Charts</h3><p>Insightful visual storytelling.</p></div><i>→</i></a>
            <a class="category-card" href="/components"><span class="category-icon icon-dashboard" aria-hidden="true">◩</span><div><h3>Dashboard</h3><p>Operational views that feel polished.</p></div><i>→</i></a>
        </div>
    </section>

    <!-- Enterprise Grid -->
    <section class="grid-spotlight" aria-labelledby="grid-title">
        <div class="spotlight-copy"><span class="eyebrow eyebrow--light">Flagship component</span><h2 id="grid-title">Data complexity,<br /><em>beautifully managed.</em></h2><p>Orizon Enterprise Grid delivers fast, dependable data experiences for demanding business applications—without compromising usability.</p><ul><li><span>✓</span> Server-side operations</li><li><span>✓</span> Virtualization</li><li><span>✓</span> Advanced filtering</li><li><span>✓</span> Batch editing</li><li><span>✓</span> Grouping & summaries</li><li><span>✓</span> Export-ready</li></ul><a class="showcase-button showcase-button--light" href="/grid">Explore Enterprise Grid <span>→</span></a></div>
        <div class="grid-demo"><div class="grid-demo-toolbar"><div><strong>Customers</strong><small>2,482 records</small></div><span>⌕ &nbsp; Search records…</span><button type="button">＋ Add customer</button></div><div class="grid-demo-table"><div class="grid-row grid-row--head"><span>Customer</span><span>Company</span><span>Status</span><span>Revenue</span></div><div class="grid-row"><span><i class="customer-avatar av-blue">AM</i><b>Alex Morgan<small>alex@north.io</small></b></span><span>Northstar Labs</span><span><em class="status-active">● Active</em></span><span><b>$48,250</b></span></div><div class="grid-row"><span><i class="customer-avatar av-violet">SK</i><b>Sarah Kim<small>sarah@apex.co</small></b></span><span>Apex Systems</span><span><em class="status-active">● Active</em></span><span><b>$36,900</b></span></div><div class="grid-row"><span><i class="customer-avatar av-orange">JD</i><b>James Davis<small>james@orbit.dev</small></b></span><span>Orbit Digital</span><span><em class="status-pending">● Pending</em></span><span><b>$21,480</b></span></div><div class="grid-row"><span><i class="customer-avatar av-green">ML</i><b>Maria Lopez<small>maria@vertex.ai</small></b></span><span>Vertex AI</span><span><em class="status-active">● Active</em></span><span><b>$18,750</b></span></div></div><footer><span>Showing 1–4 of 2,482</span><span>‹ &nbsp; <b>1</b> &nbsp; 2 &nbsp; 3 &nbsp; ··· &nbsp; 621 &nbsp; ›</span></footer></div>
    </section>

    <!-- Application templates -->
    <section class="showcase-section templates" aria-labelledby="templates-title">
        <header class="section-heading"><span class="eyebrow">Application starters</span><h2 id="templates-title">From idea to product, faster.</h2><p>Thoughtfully designed application patterns for the industries and workflows that run modern business.</p></header>
        <div class="template-grid">
            <article class="template-card template-card--crm"><div class="template-visual"><span class="mini-rail"></span><div><i></i><i></i><b></b></div></div><footer><span class="template-symbol">◎</span><div><h3>CRM</h3><p>Pipeline & customer operations</p></div><i>→</i></footer></article>
            <article class="template-card template-card--erp"><div class="template-visual"><span class="mini-rail"></span><div><b></b><i></i><i></i></div></div><footer><span class="template-symbol">▦</span><div><h3>ERP</h3><p>Resources & operations</p></div><i>→</i></footer></article>
            <article class="template-card template-card--health"><div class="template-visual"><span class="mini-rail"></span><div><i></i><b></b><i></i></div></div><footer><span class="template-symbol">✚</span><div><h3>Healthcare</h3><p>Patient & clinical workflows</p></div><i>→</i></footer></article>
            <article class="template-card template-card--estate"><div class="template-visual"><span class="mini-rail"></span><div><b></b><i></i><i></i></div></div><footer><span class="template-symbol">⌂</span><div><h3>Real Estate</h3><p>Properties & opportunities</p></div><i>→</i></footer></article>
            <article class="template-card template-card--distribution"><div class="template-visual"><span class="mini-rail"></span><div><i></i><i></i><b></b></div></div><footer><span class="template-symbol">⬡</span><div><h3>Distribution</h3><p>Inventory & logistics</p></div><i>→</i></footer></article>
            <article class="template-card template-card--ai"><div class="template-visual"><span class="mini-rail"></span><div><i></i><b></b><i></i></div></div><footer><span class="template-symbol">✦</span><div><h3>AI</h3><p>Intelligent experiences</p></div><i>→</i></footer></article>
        </div>
    </section>

    <!-- Roadmap -->
    <section class="showcase-section roadmap" aria-labelledby="roadmap-title">
        <header class="section-heading"><span class="eyebrow">What is next</span><h2 id="roadmap-title">Built for the long run.</h2><p>A clear path from a strong foundation to a complete enterprise platform.</p></header>
        <div class="roadmap-line" aria-hidden="true"></div>
        <div class="roadmap-grid">
            <article class="roadmap-item is-current"><span><i>✓</i> Available now</span><strong>v1</strong><h3>The foundation</h3><p>Core components, design tokens, theming, accessibility and Enterprise Grid.</p><small>CORE SYSTEM</small></article>
            <article class="roadmap-item"><span><i></i> In development</span><strong>v1.5</strong><h3>Productivity at scale</h3><p>Advanced data workflows, more templates and expanded charting capabilities.</p><small>EXPANSION</small></article>
            <article class="roadmap-item"><span><i></i> On the horizon</span><strong>v2</strong><h3>The platform</h3><p>Visual tooling, AI-assisted workflows and a complete enterprise ecosystem.</p><small>NEXT GENERATION</small></article>
        </div>
    </section>

    <!-- Footer -->
    <footer class="showcase-footer"><div><b><span>O</span> Orizon UI</b><p>Enterprise interfaces, engineered with care.</p></div><span>ASP.NET Core MVC · .NET 8 · Razor Class Library</span></footer>
</main>
