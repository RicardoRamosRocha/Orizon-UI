        <!-- ===================================================== -->
    <!-- COMPONENT CATEGORIES                                  -->
    <!-- ===================================================== -->

    <section class="categories-section">

        <div class="section-header">

            <span class="section-tag">
                Components
            </span>

            <h2>
                Everything organized by category
            </h2>

            <p>
                Build dashboards, ERPs, CRMs and enterprise systems with reusable components.
            </p>

        </div>

        <div class="categories-grid">

            <article class="category-card">

                <div class="category-icon foundation"></div>

                <h3>
                    Foundations
                </h3>

                <p>
                    Colors, Typography, Spacing, Elevation and Design Tokens.
                </p>

                <ul>

                    <li>Design Tokens</li>

                    <li>Typography</li>

                    <li>Colors</li>

                    <li>Spacing</li>

                </ul>

                <a href="/components">
                    Explore →
                </a>

            </article>

            <article class="category-card">

                <div class="category-icon forms"></div>

                <h3>
                    Forms
                </h3>

                <p>
                    Complete form controls for enterprise applications.
                </p>

                <ul>

                    <li>Input</li>

                    <li>Select</li>

                    <li>Textarea</li>

                    <li>Checkbox</li>

                </ul>

                <a href="/components/forms">
                    Explore →
                </a>

            </article>

            <article class="category-card">

                <div class="category-icon data"></div>

                <h3>
                    Data
                </h3>

                <p>
                    Powerful data visualization components.
                </p>

                <ul>

                    <li>Grid</li>

                    <li>Tables</li>

                    <li>Pagination</li>

                    <li>Virtualization</li>

                </ul>

                <a href="/grid">
                    Explore →
                </a>

            </article>

            <article class="category-card">

                <div class="category-icon navigation"></div>

                <h3>
                    Navigation
                </h3>

                <p>
                    Modern navigation experience.
                </p>

                <ul>

                    <li>Sidebar</li>

                    <li>Tabs</li>

                    <li>Dropdown</li>

                    <li>Breadcrumb</li>

                </ul>

                <a href="/components">
                    Explore →
                </a>

            </article>

            <article class="category-card">

                <div class="category-icon feedback"></div>

                <h3>
                    Feedback
                </h3>

                <p>
                    Inform users with elegant interactions.
                </p>

                <ul>

                    <li>Alert</li>

                    <li>Toast</li>

                    <li>Progress</li>

                    <li>Spinner</li>

                </ul>

                <a href="/components">
                    Explore →
                </a>

            </article>

            <article class="category-card featured">

                <span class="featured-badge">
                    Enterprise
                </span>

                <div class="category-icon enterprise"></div>

                <h3>
                    Enterprise Grid
                </h3>

                <p>
                    The flagship component of Orizon UI.
                </p>

                <ul>

                    <li>Server Mode</li>

                    <li>Grouping</li>

                    <li>Filtering</li>

                    <li>Batch Editing</li>

                    <li>Infinite Scroll</li>

                    <li>Tree Data</li>

                </ul>

                <a href="/grid">
                    Open Showcase →
                </a>

            </article>

        </div>

    </section>

