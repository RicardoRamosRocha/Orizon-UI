@{
    ViewData["Title"] = "Orizon UI";
    ViewData["ApplicationName"] = "Orizon UI";
}

@section Styles
{
    <link rel="stylesheet"
          href="~/css/showcase.css"
          asp-append-version="true" />
}

<div class="showcase">

    <!-- ===================================================== -->
    <!-- HERO                                                   -->
    <!-- ===================================================== -->

    <section class="hero">

        <div class="hero-background">

            <div class="gradient gradient-1"></div>
            <div class="gradient gradient-2"></div>
            <div class="gradient gradient-3"></div>

        </div>

        <div class="hero-content">

            <div class="hero-left">

                <span class="hero-badge">

                    <svg viewBox="0 0 24 24">
                        <path d="M12 2L15 8L22 9L17 14L18 22L12 19L6 22L7 14L2 9L9 8Z"/>
                    </svg>

                    Enterprise UI Library

                </span>

                <h1 class="hero-title">

                    Build Enterprise
                    <br />
                    Applications Faster

                </h1>

                <p class="hero-description">

                    Modern UI components for ASP.NET Core MVC.

                    Build dashboards, ERPs, CRMs and enterprise
                    applications with a professional Design System.

                </p>

                <div class="hero-actions">

                    <a href="/components"
                       class="hero-button hero-button-primary">

                        Explore Components

                    </a>

                    <a href="/grid"
                       class="hero-button hero-button-secondary">

                        Enterprise Grid

                    </a>

                </div>

                <div class="hero-stats">

                    <div class="hero-stat">

                        <strong>320+</strong>

                        <span>Components</span>

                    </div>

                    <div class="hero-stat">

                        <strong>160+</strong>

                        <span>SVG Icons</span>

                    </div>

                    <div class="hero-stat">

                        <strong>9</strong>

                        <span>Themes</span>

                    </div>

                </div>

            </div>

            <div class="hero-right">

                <div class="preview-window">

                    <div class="preview-header">

                        <div class="window-actions">

                            <span></span>
                            <span></span>
                            <span></span>

                        </div>

                        <div class="window-title">

                            Dashboard Preview

                        </div>

                    </div>

                    <div class="preview-body">

                        <div class="preview-sidebar">

                            <div class="sidebar-logo">

                                O

                            </div>

                            <div class="sidebar-item active"></div>
                            <div class="sidebar-item"></div>
                            <div class="sidebar-item"></div>
                            <div class="sidebar-item"></div>
                            <div class="sidebar-item"></div>

                        </div>

                        <div class="preview-content">

                            <div class="preview-topbar">

                                <div class="search"></div>

                                <div class="avatar"></div>

                            </div>

                            <div class="mini-kpis">

                                <div class="mini-card">

                                    <small>Revenue</small>

                                    <h3>$42,580</h3>

                                    <span class="positive">

                                        ▲ 12%

                                    </span>

                                </div>

                                <div class="mini-card">

                                    <small>Orders</small>

                                    <h3>8,254</h3>

                                    <span class="positive">

                                        ▲ 9%

                                    </span>

                                </div>

                                <div class="mini-card">

                                    <small>Customers</small>

                                    <h3>2,914</h3>

                                    <span class="positive">

                                        ▲ 17%

                                    </span>

                                </div>

                            </div>

                            <div class="preview-grid">

                                                                <div class="grid-card">

                                    <div class="grid-card-header">

                                        <div class="grid-title">

                                            Enterprise Grid

                                        </div>

                                        <span class="grid-badge">

                                            Server Mode

                                        </span>

                                    </div>

                                    <table class="demo-grid">

                                        <thead>

                                            <tr>

                                                <th>ID</th>
                                                <th>Customer</th>
                                                <th>Status</th>
                                                <th>Total</th>

                                            </tr>

                                        </thead>

                                        <tbody>

                                            <tr>

                                                <td>#1025</td>

                                                <td>Acme Inc.</td>

                                                <td>

                                                    <span class="status success">

                                                        Active

                                                    </span>

                                                </td>

                                                <td>$12,450</td>

                                            </tr>

                                            <tr>

                                                <td>#1026</td>

                                                <td>Northwind</td>

                                                <td>

                                                    <span class="status warning">

                                                        Pending

                                                    </span>

                                                </td>

                                                <td>$8,920</td>

                                            </tr>

                                            <tr>

                                                <td>#1027</td>

                                                <td>Contoso</td>

                                                <td>

                                                    <span class="status success">

                                                        Paid

                                                    </span>

                                                </td>

                                                <td>$5,640</td>

                                            </tr>

                                            <tr>

                                                <td>#1028</td>

                                                <td>Adventure</td>

                                                <td>

                                                    <span class="status danger">

                                                        Overdue

                                                    </span>

                                                </td>

                                                <td>$2,190</td>

                                            </tr>

