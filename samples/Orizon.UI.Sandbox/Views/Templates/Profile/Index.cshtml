@{ ViewData["Title"] = "User Profile Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("User Profile", "Central pessoal para identidade, preferências, segurança e sessões ativas."))' />
<div class="template-panel template-profile-head"><div class="template-profile-head"><orizon-avatar name="Marina Costa" size="xl" status="online" /><div><h2>Marina Costa</h2><p>Product Manager · marina@orizon.com</p><orizon-chip text="Administradora" color="primary" /></div></div><orizon-button text="Alterar foto" variant="outline" /></div>
<orizon-tabs label="Configurações do perfil"><div class="orizon-tabs__list orizon-scrollbar" role="tablist" aria-label="Configurações do perfil"><button class="orizon-tabs__tab" id="profile-data-tab" type="button" role="tab" aria-selected="true" aria-controls="profile-data">Dados pessoais</button><button class="orizon-tabs__tab" id="profile-prefs-tab" type="button" role="tab" aria-selected="false" aria-controls="profile-prefs" tabindex="-1">Preferências</button><button class="orizon-tabs__tab" id="profile-security-tab" type="button" role="tab" aria-selected="false" aria-controls="profile-security" tabindex="-1">Segurança</button></div>
<section class="orizon-tabs__panel" id="profile-data" role="tabpanel" tabindex="0" aria-labelledby="profile-data-tab"><orizon-card title="Informações pessoais"><div class="template-form-grid"><orizon-text-box name="Name" label="Nome completo" value="Marina Costa" /><orizon-email name="Email" label="E-mail" value="marina@orizon.com" /><orizon-phone name="Phone" label="Telefone" value="11999998888" /><orizon-date-picker name="BirthDate" label="Data de nascimento" /></div><div class="orizon-form-actions"><orizon-button text="Salvar dados" /></div></orizon-card></section>
<section class="orizon-tabs__panel" id="profile-prefs" role="tabpanel" tabindex="0" aria-labelledby="profile-prefs-tab" hidden><orizon-card title="Preferências"><div class="template-stack"><orizon-switch name="DarkPreference" label="Preferir tema escuro" /><orizon-switch name="EmailNotifications" label="Notificações por e-mail" checked /><orizon-select name="Language" label="Idioma"><option>Português (Brasil)</option><option>English</option></orizon-select></div></orizon-card></section>
<section class="orizon-tabs__panel" id="profile-security" role="tabpanel" tabindex="0" aria-labelledby="profile-security-tab" hidden><div class="template-grid"><orizon-card title="Alterar senha"><div class="template-stack"><orizon-password name="OldPassword" label="Senha atual" /><orizon-password name="ProfileNewPassword" label="Nova senha" strength /><orizon-button text="Atualizar senha" /></div></orizon-card><orizon-card title="Sessões ativas"><div class="template-stack"><p><strong>Chrome · São Paulo</strong><br /><small>Sessão atual · agora</small></p><p><strong>Safari · iPhone</strong><br /><small>Último acesso ontem</small></p><orizon-button text="Encerrar outras sessões" variant="outline" color="danger" /></div></orizon-card></div></section></orizon-tabs></div>
