@{ ViewData["Title"] = "Authentication Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("Authentication", "Fluxos de acesso consistentes para login, cadastro, recuperação, confirmação e 2FA."))' />
<div class="template-auth-shell"><div class="template-auth-card"><orizon-tabs label="Fluxos de autenticação"><div class="orizon-tabs__list orizon-scrollbar" role="tablist" aria-label="Fluxos de autenticação"><button class="orizon-tabs__tab" id="auth-login-tab" type="button" role="tab" aria-selected="true" aria-controls="auth-login">Login</button><button class="orizon-tabs__tab" id="auth-register-tab" type="button" role="tab" aria-selected="false" aria-controls="auth-register" tabindex="-1">Cadastro</button><button class="orizon-tabs__tab" id="auth-recovery-tab" type="button" role="tab" aria-selected="false" aria-controls="auth-recovery" tabindex="-1">Recuperação</button><button class="orizon-tabs__tab" id="auth-2fa-tab" type="button" role="tab" aria-selected="false" aria-controls="auth-2fa" tabindex="-1">2FA</button></div>
<section class="orizon-tabs__panel" id="auth-login" role="tabpanel" tabindex="0" aria-labelledby="auth-login-tab"><orizon-card title="Bem-vindo de volta" subtitle="Entre na sua conta Orizon"><form class="template-stack"><orizon-email name="LoginEmail" label="E-mail" autocomplete="email" required /><orizon-password name="LoginPassword" label="Senha" required /><orizon-switch name="Remember" label="Manter conectado" /><orizon-button type="submit" text="Entrar" /><a href="#auth-recovery">Esqueci minha senha</a></form></orizon-card></section>
<section class="orizon-tabs__panel" id="auth-register" role="tabpanel" tabindex="0" aria-labelledby="auth-register-tab" hidden><orizon-card title="Criar conta" subtitle="Comece seu workspace"><form class="template-stack"><orizon-text-box name="FullName" label="Nome completo" required /><orizon-email name="RegisterEmail" label="E-mail" required /><orizon-password name="RegisterPassword" label="Senha" strength required /><orizon-button type="submit" text="Criar conta" /></form></orizon-card></section>
<section class="orizon-tabs__panel" id="auth-recovery" role="tabpanel" tabindex="0" aria-labelledby="auth-recovery-tab" hidden><orizon-card title="Recuperar acesso" subtitle="Enviaremos um link seguro"><form class="template-stack"><orizon-email name="RecoveryEmail" label="E-mail da conta" required /><orizon-button type="submit" text="Enviar link" /><orizon-alert variant="success" title="Confirmação preparada">A mensagem de sucesso aparece nesta mesma região.</orizon-alert></form></orizon-card></section>
<section class="orizon-tabs__panel" id="auth-2fa" role="tabpanel" tabindex="0" aria-labelledby="auth-2fa-tab" hidden><orizon-card title="Verificação em duas etapas" subtitle="Digite o código do aplicativo"><form class="template-stack"><orizon-text-box name="Code" label="Código de 6 dígitos" maxlength="6" inputmode="numeric" required /><orizon-button type="submit" text="Confirmar acesso" /><p><small>A tela também comporta confirmação de e-mail e alteração de senha por token.</small></p></form></orizon-card></section></orizon-tabs></div></div>
<section data-theme="dark" class="template-auth-shell"><orizon-card class="template-auth-card" title="Alterar senha" subtitle="Exemplo no tema escuro"><form class="template-stack"><orizon-password name="CurrentPassword" label="Senha atual" /><orizon-password name="NewPassword" label="Nova senha" strength /><orizon-button text="Atualizar senha" /></form></orizon-card></section></div>
