@{ ViewData["Title"] = "Settings Workspace Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("Settings Workspace", "Configurações organizacionais com navegação clara, alterações seguras e feedback imediato."))' />
<orizon-toolbar sticky label="Ações das configurações"><div data-toolbar-group><orizon-button text="Cancelar" variant="outline" color="neutral" /></div><div data-toolbar-right><orizon-button text="Salvar alterações" /></div></orizon-toolbar>
<div class="template-settings"><nav class="template-panel template-settings__nav" aria-label="Seções de configuração"><a href="#general" aria-current="page">Geral</a><a href="#notifications">Notificações</a><a href="#security">Segurança</a><a href="#integrations">Integrações</a></nav><main class="template-stack" id="general"><orizon-card title="Informações do workspace" subtitle="Identidade visível para toda a equipe"><div class="template-form-grid"><orizon-text-box name="WorkspaceName" label="Nome" value="Orizon Platform" /><orizon-text-box name="Slug" label="Identificador" value="orizon-platform" /><orizon-email name="BillingEmail" label="E-mail financeiro" value="financeiro@orizon.com" /><orizon-select name="Timezone" label="Fuso horário"><option>America/Sao_Paulo</option><option>UTC</option></orizon-select></div></orizon-card>
<orizon-card title="Preferências" subtitle="Experiência padrão dos usuários"><div class="template-stack"><orizon-switch name="WeeklyDigest" label="Resumo semanal" description="Enviar indicadores toda segunda-feira." checked /><orizon-switch name="CompactMode" label="Modo compacto" description="Reduzir o espaçamento em telas densas." /><orizon-switch name="ProductUpdates" label="Novidades do produto" description="Avisar administradores sobre novos recursos." checked /></div></orizon-card>
<orizon-accordion mode="single"><orizon-accordion-item title="Segurança e autenticação" icon="shield-check" expanded><div class="template-form-grid"><orizon-select name="SessionDuration" label="Duração da sessão"><option>8 horas</option><option>24 horas</option></orizon-select><orizon-switch name="Require2FA" label="Exigir autenticação em dois fatores" /></div></orizon-accordion-item><orizon-accordion-item title="Integrações" icon="plugs"><p>Conecte serviços corporativos sem alterar a experiência do workspace.</p><orizon-button text="Gerenciar integrações" variant="outline" /></orizon-accordion-item></orizon-accordion>
<div class="template-toolbar-row"><p><small>Alterações não salvas</small></p><div><orizon-button text="Cancelar" variant="outline" color="neutral" /><orizon-button text="Salvar alterações" /></div></div></main></div></div>
