@{ ViewData["Title"] = "Admin Dashboard Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("Admin Dashboard", "Visão operacional para acompanhar negócio, equipe e alertas em um único lugar."))' />
<orizon-toolbar sticky label="Ações do dashboard"><div data-toolbar-group><orizon-button text="Novo relatório" icon="plus" /><orizon-button text="Exportar" variant="outline" color="neutral" /></div><div data-toolbar-right><button class="orizon-button orizon-button--soft orizon-button--primary" type="button" data-notifications-target="#admin-notifications">Notificações</button></div></orizon-toolbar>
<orizon-dashboard-grid columns="12" responsive><orizon-metric-card title="Receita mensal" value="R$ 428 mil" variation="+12,8%" trend="positive" sparkline="[32,38,36,45,52,61,68]" /><orizon-metric-card title="Pedidos" value="1.842" variation="+8,4%" trend="positive" sparkline="[20,26,24,31,29,38,44]" /><orizon-metric-card title="SLA médio" value="4h 18m" variation="-22 min" trend="positive" /></orizon-dashboard-grid>
<div class="template-grid"><orizon-dashboard-widget title="Receita e meta" subtitle="Últimos seis meses"><orizon-chart type="area" labels='["Fev","Mar","Abr","Mai","Jun","Jul"]' series='[{"name":"Receita","data":[280,310,298,356,392,428]},{"name":"Meta","data":[300,320,340,360,390,420]}]' height="280" legend tooltip /></orizon-dashboard-widget><orizon-dashboard-widget title="Saúde operacional"><div class="template-toolbar-row"><orizon-progress-ring value="82" label="Meta" status="success" /><orizon-gauge value="74" label="SLA" unit="%" ticks="5" /></div></orizon-dashboard-widget></div>
<div class="template-grid"><orizon-activity-feed label="Atividade recente"><section data-activity-group><h3>Hoje</h3><article data-activity-item><span data-activity-avatar>AM</span><div><p><strong>Ana</strong> aprovou o pedido #4821.</p><time>há 8 min</time></div></article><article data-activity-item><span data-activity-avatar>JL</span><div><p><strong>João</strong> atualizou a previsão de vendas.</p><time>há 26 min</time></div></article></section></orizon-activity-feed><orizon-quick-actions label="Ações rápidas" columns="2"><div data-quick-action="order"><span data-quick-icon>＋</span><a href="#"><strong>Novo pedido</strong><small>Iniciar venda</small></a></div><div data-quick-action="customer"><span data-quick-icon>◎</span><a href="#"><strong>Clientes</strong><small>Abrir carteira</small></a></div></orizon-quick-actions></div>
<orizon-notification-center id="admin-notifications" unread-count="2"><orizon-notification title="Meta atingida" time="Agora" unread>A equipe Sul superou a meta semanal.</orizon-notification><orizon-notification title="Integração estável" time="há 12 min" unread>Todos os serviços estão operacionais.</orizon-notification></orizon-notification-center></div>
