@{ ViewData["Title"] = "Analytics Dashboard Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("Analytics Dashboard", "Leitura executiva de receita, retenção, canais e performance operacional."))' />
<orizon-command-bar title="Performance executiva" subtitle="Atualizado há 5 minutos" breadcrumb="Analytics / Visão geral" primary-text="Exportar PDF"><orizon-chip text="Últimos 6 meses" color="primary" selected /></orizon-command-bar>
<orizon-dashboard-grid columns="12" responsive><orizon-metric-card title="ARR" value="R$ 5,14 mi" variation="+18,2%" trend="positive" sparkline="[42,48,53,57,62,68]" /><orizon-metric-card title="Retenção" value="92,4%" variation="+1,8 p.p." trend="positive" /><orizon-metric-card title="CAC" value="R$ 384" variation="-7,2%" trend="positive" /></orizon-dashboard-grid>
<div class="template-grid"><orizon-dashboard-widget title="Receita por período" subtitle="Realizado versus previsto"><orizon-chart type="line" labels='["Fev","Mar","Abr","Mai","Jun","Jul"]' series='[{"name":"Realizado","data":[610,680,720,790,850,920]},{"name":"Previsto","data":[640,670,730,780,840,900]}]' height="300" legend tooltip grid axis /></orizon-dashboard-widget><orizon-dashboard-widget title="Mix de receita"><orizon-chart type="doughnut" labels='["Enterprise","Growth","Starter"]' series='[{"name":"Receita","data":[52,31,17]}]' height="300" legend tooltip axis="false" grid="false" /></orizon-dashboard-widget></div>
<div class="template-grid"><div class="template-panel"><h2>Indicadores de qualidade</h2><div class="template-toolbar-row"><orizon-progress-ring value="88" label="NPS" status="success" /><orizon-gauge value="76" label="Eficiência" unit="%" ticks="6" /></div></div><div class="template-panel"><h2>Tendências</h2><p>Conversão <orizon-sparkline type="line" values="[22,28,25,34,39,46]" label="Conversão crescente" /></p><p>Churn <orizon-sparkline type="area" values="[6,5,5,4,3,2]" label="Churn decrescente" /></p></div></div>
<section data-theme="dark" class="template-panel"><h2>Estado alternativo em tema escuro</h2><orizon-chart-empty-state title="Dados insuficientes" description="Selecione um período maior para comparar as coortes." icon="chart-line" action-label="Alterar período" action-href="#" /></section></div>
