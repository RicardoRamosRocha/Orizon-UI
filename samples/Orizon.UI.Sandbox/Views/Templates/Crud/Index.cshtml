@{ ViewData["Title"] = "CRUD Workspace Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("CRUD Workspace", "Gestão profissional de clientes com pesquisa, filtros, seleção e estados operacionais."))' />
<orizon-command-bar title="Clientes" subtitle="2.486 registros ativos" breadcrumb="CRM / Clientes" search search-placeholder="Pesquisar cliente" primary-text="Novo cliente"><button class="orizon-button orizon-button--outline orizon-button--neutral" type="button" data-drawer-target="crud-filters">Filtros</button></orizon-command-bar>
<orizon-toolbar sticky label="Ações da lista"><div data-toolbar-group><orizon-button text="Exportar" icon="download" variant="outline" /><button class="orizon-button orizon-button--outline orizon-button--danger" type="button" data-confirm-target="#crud-delete">Excluir</button></div><div data-toolbar-right><orizon-search-box placeholder="Nome, documento ou e-mail" shortcut full-width /></div></orizon-toolbar>
<orizon-filter-bar count="2"><orizon-chip text="Status: ativo" color="success" selected removable /><orizon-chip text="Segmento: Enterprise" color="primary" removable /></orizon-filter-bar>
<orizon-data-table label="Clientes cadastrados" striped hover sortable searchable selectable sticky-header pageable page="1" total-pages="12"><thead><tr><th><input type="checkbox" aria-label="Selecionar todos" /></th><th>Cliente</th><th>Segmento</th><th>Status</th><th>Receita</th></tr></thead><tbody><tr tabindex="0"><td><input type="checkbox" aria-label="Selecionar Acme" /></td><td><strong>Acme Brasil</strong><br /><small>contato@acme.com</small></td><td>Enterprise</td><td><orizon-chip text="Ativo" color="success" size="sm" /></td><td>R$ 48.200</td></tr><tr tabindex="0"><td><input type="checkbox" aria-label="Selecionar Aurora" /></td><td><strong>Aurora Labs</strong><br /><small>hello@aurora.io</small></td><td>Growth</td><td><orizon-chip text="Trial" color="warning" size="sm" /></td><td>R$ 8.900</td></tr><tr tabindex="0"><td><input type="checkbox" aria-label="Selecionar Horizonte" /></td><td><strong>Grupo Horizonte</strong><br /><small>financeiro@horizonte.com</small></td><td>Enterprise</td><td><orizon-chip text="Ativo" color="success" size="sm" /></td><td>R$ 72.400</td></tr></tbody></orizon-data-table>
<div class="template-grid"><div class="template-panel"><h2>Estados previstos</h2><div class="template-stack"><orizon-loading-overlay active="false" text="Atualizando clientes"><p>Loading overlay preparado para operações assíncronas.</p></orizon-loading-overlay><orizon-alert variant="danger" title="Falha ao sincronizar">O workspace mantém o contexto e oferece nova tentativa.</orizon-alert></div></div><orizon-quick-actions label="Ações frequentes" columns="2"><div data-quick-action="import"><span data-quick-icon>⇧</span><a href="#"><strong>Importar</strong><small>Arquivo CSV</small></a></div><div data-quick-action="segment"><span data-quick-icon>◎</span><a href="#"><strong>Segmentar</strong><small>Criar audiência</small></a></div></orizon-quick-actions></div>
<orizon-drawer id="crud-filters" title="Filtros avançados"><div class="template-stack"><orizon-select name="Status" label="Status"><option>Todos</option><option>Ativo</option></orizon-select><orizon-text-box name="Owner" label="Responsável" placeholder="Nome da pessoa" /><orizon-date-picker name="CreatedAfter" label="Criado após" /><orizon-button text="Aplicar filtros" /></div></orizon-drawer><orizon-confirm-dialog id="crud-delete" title="Excluir clientes?" message="Os registros selecionados serão removidos permanentemente." type="danger" confirm-text="Excluir selecionados" /></div>
