@{ ViewData["Title"] = "Kanban Workspace Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("Kanban Workspace", "Planejamento colaborativo com prioridades, responsáveis e histórico do fluxo."))' />
<orizon-command-bar title="Roadmap do produto" subtitle="Sprint 28 · 14 itens" breadcrumb="Produto / Roadmap" search primary-text="Nova tarefa"><button class="orizon-button orizon-button--outline orizon-button--neutral" data-drawer-target="kanban-filter" type="button">Filtros</button></orizon-command-bar>
<orizon-filter-bar count="2"><orizon-chip text="Equipe: Plataforma" color="primary" removable /><orizon-chip text="Sprint atual" color="success" removable /></orizon-filter-bar>
<orizon-kanban label="Roadmap do produto" draggable persist-key="template-kanban"><section data-kanban-column data-column-id="todo"><header><h3>A fazer</h3><span>2</span></header><div data-kanban-list><article draggable="true" tabindex="0" data-kanban-card data-card-id="billing" data-priority="high"><orizon-badge variant="danger">Alta</orizon-badge><h4>Revisar cobrança</h4><p>Responsável: Marina</p></article><article draggable="true" tabindex="0" data-kanban-card data-card-id="audit"><h4>Auditoria de permissões</h4><p>Responsável: Caio</p></article></div></section><section data-kanban-column data-column-id="doing"><header><h3>Em andamento</h3><span>1</span></header><div data-kanban-list><article draggable="true" tabindex="0" data-kanban-card data-card-id="portal"><orizon-badge variant="warning">Média</orizon-badge><h4>Novo portal</h4><p>Responsável: Lia</p></article></div></section><section data-kanban-column data-column-id="done"><header><h3>Concluído</h3><span>1</span></header><div data-kanban-list><article draggable="true" tabindex="0" data-kanban-card data-card-id="tokens"><h4>Tokens semânticos</h4><p>Responsável: Design</p></article></div></section></orizon-kanban>
<div class="template-grid"><orizon-activity-feed label="Atualizações"><section data-activity-group><h3>Hoje</h3><article data-activity-item><span data-activity-avatar>MC</span><div><p>Marina priorizou “Revisar cobrança”.</p><time>há 14 min</time></div></article></section></orizon-activity-feed><orizon-quick-actions label="Atalhos" columns="2"><div data-quick-action="meeting"><span data-quick-icon>◫</span><a href="#"><strong>Daily</strong><small>Abrir pauta</small></a></div><div data-quick-action="report"><span data-quick-icon>▥</span><a href="#"><strong>Relatório</strong><small>Ver sprint</small></a></div></orizon-quick-actions></div>
<orizon-drawer id="kanban-filter" title="Filtros do quadro"><orizon-select name="Team" label="Equipe"><option>Plataforma</option><option>Produto</option></orizon-select><orizon-select name="Priority" label="Prioridade"><option>Todas</option><option>Alta</option></orizon-select></orizon-drawer></div>
