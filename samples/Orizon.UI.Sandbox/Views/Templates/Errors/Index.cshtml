@{ ViewData["Title"] = "Error Pages Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("Errors & Empty States", "Mensagens acionáveis e consistentes para falhas, restrições e ausência de conteúdo."))' />
<div class="template-error-grid"><orizon-empty-state title="401 · Autenticação necessária" description="Entre novamente para continuar com segurança." icon="ph ph-lock"><orizon-button text="Entrar" /></orizon-empty-state><orizon-empty-state title="403 · Acesso restrito" description="Você não possui permissão para visualizar este recurso." icon="ph ph-shield-warning"><orizon-button text="Voltar" variant="outline" /></orizon-empty-state><orizon-empty-state title="404 · Página não encontrada" description="O endereço pode ter mudado ou não existe mais." icon="ph ph-map-trifold"><orizon-button text="Ir ao início" /></orizon-empty-state><orizon-empty-state title="500 · Algo deu errado" description="Registramos o problema. Tente novamente em alguns instantes." icon="ph ph-warning-octagon"><orizon-button text="Tentar novamente" /></orizon-empty-state><orizon-empty-state title="Você está offline" description="Confira sua conexão para sincronizar as alterações." icon="ph ph-wifi-slash"><orizon-button text="Verificar conexão" variant="outline" /></orizon-empty-state><orizon-empty-state title="Nenhum dado ainda" description="Crie o primeiro registro para começar." icon="ph ph-database"><orizon-button text="Criar registro" /></orizon-empty-state><orizon-empty-state title="Nenhum resultado" description="Tente remover filtros ou usar outros termos de pesquisa." icon="ph ph-magnifying-glass"><orizon-button text="Limpar pesquisa" variant="outline" /></orizon-empty-state><orizon-empty-state title="Erro de rede" description="Não foi possível carregar os dados mais recentes." icon="ph ph-cloud-x"><orizon-button text="Recarregar" /></orizon-empty-state></div>
<section data-theme="dark" class="template-panel"><orizon-empty-state title="Estado vazio no tema escuro" description="A mesma composição preserva contraste e hierarquia visual." icon="ph ph-inbox"><orizon-button text="Adicionar conteúdo" /></orizon-empty-state></section></div>
