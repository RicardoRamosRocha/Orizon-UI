@using Microsoft.AspNetCore.Mvc.Rendering
@{ ViewData["Title"] = "Entity Form Template"; var sectors = new[]{new SelectListItem("Tecnologia","tech"),new SelectListItem("Varejo","retail"),new SelectListItem("Serviços","services")}; var tags = new[]{new SelectListItem("Enterprise","enterprise"),new SelectListItem("Parceiro","partner")}; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("Entity Form", "Cadastro empresarial completo, organizado em seções e preparado para um fluxo em etapas."))' />
<orizon-toolbar sticky label="Ações do cadastro"><div data-toolbar-group><orizon-button href="/components/templates" text="Cancelar" variant="outline" color="neutral" /></div><div data-toolbar-right><orizon-button type="submit" text="Salvar rascunho" variant="outline" /><orizon-button type="submit" text="Salvar empresa" /></div></orizon-toolbar>
<nav class="template-panel" aria-label="Etapas do cadastro"><div class="template-toolbar-row"><orizon-chip text="1. Identificação" color="primary" selected /><orizon-chip text="2. Contatos" /><orizon-chip text="3. Comercial" /><orizon-chip text="4. Documentos" /></div></nav>
<form class="template-stack"><orizon-card title="Identificação da empresa" subtitle="Dados fiscais e informações principais" icon="buildings"><div class="template-form-grid"><orizon-text-box name="CompanyName" label="Razão social" required /><orizon-text-box name="TradeName" label="Nome fantasia" required /><orizon-cnpj name="Cnpj" label="CNPJ" required /><orizon-cep name="Cep" label="CEP" /><orizon-email name="Email" label="E-mail corporativo" /><orizon-phone name="Phone" label="Telefone" /></div></orizon-card>
<orizon-card title="Informações comerciais" subtitle="Segmentação e condições"><div class="template-form-grid"><orizon-select name="Sector" label="Setor" items="sectors" required /><orizon-multi-select name="Tags" label="Marcadores" items="tags" /><orizon-number name="Employees" label="Número de funcionários" min="1" /><orizon-currency name="Revenue" label="Faturamento mensal" /><orizon-date-picker name="FoundedAt" label="Data de fundação" /><orizon-time-picker name="ContactTime" label="Melhor horário" /><orizon-date-time-picker name="NextReview" label="Próxima revisão" /><orizon-rating name="Potential" label="Potencial comercial" value="4" /></div></orizon-card>
<orizon-card title="Responsável e documentos" subtitle="Contato principal e anexos"><div class="template-form-grid"><orizon-text-box name="Owner" label="Responsável" /><orizon-cpf name="OwnerCpf" label="CPF do responsável" /><orizon-drag-drop-upload name="Documents" label="Contrato e documentos" multiple accept=".pdf,image/*" /><orizon-file-upload name="Logo" label="Logotipo" accept="image/*" preview /></div></orizon-card>
<div class="template-toolbar-row"><p><small>Último salvamento automático: agora</small></p><div><orizon-button text="Cancelar" variant="outline" color="neutral" /><orizon-button type="submit" text="Salvar empresa" /></div></div></form></div>
