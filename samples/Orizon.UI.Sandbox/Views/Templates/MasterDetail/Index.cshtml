@{ ViewData["Title"] = "Master Detail Template"; }
<div class="template-page"><partial name="~/Views/Templates/Shared/_TemplateHeader.cshtml" model='@(("Master Detail", "Navegação por contas e detalhes completos sem perder o contexto da seleção."))' />
<orizon-command-bar title="Carteira de contas" subtitle="Relacionamento e histórico" breadcrumb="Comercial / Contas" search primary-text="Nova conta"><button class="orizon-button orizon-button--outline orizon-button--neutral" type="button" data-drawer-target="account-notes">Anotações</button></orizon-command-bar>
<orizon-split-view initial-size="34" min-size="25" max-size="55" resizable collapsible persist-key="template-master-detail"><section data-split-primary><div class="template-stack"><orizon-search-box placeholder="Pesquisar contas" full-width /><orizon-tree-view label="Contas por segmento"><ul><li role="treeitem" tabindex="0" aria-expanded="true"><div><button data-tree-toggle type="button" aria-label="Recolher Enterprise">▾</button><strong>Enterprise</strong></div><ul role="group"><li role="treeitem" tabindex="-1"><div>Acme Brasil</div></li><li role="treeitem" tabindex="-1"><div>Grupo Horizonte</div></li></ul></li><li role="treeitem" tabindex="-1" aria-expanded="false"><div><button data-tree-toggle type="button" aria-label="Expandir Growth">▸</button><strong>Growth</strong></div><ul role="group"><li role="treeitem" tabindex="-1"><div>Aurora Labs</div></li></ul></li></ul></orizon-tree-view></div></section>
<section data-split-secondary><div class="template-stack"><div class="template-profile-head"><div><h2>Acme Brasil</h2><p>Enterprise · Cliente desde 2023</p></div><orizon-chip text="Saudável" color="success" selected /></div><div class="template-grid"><orizon-stat-card title="MRR" value="R$ 48.200" trend="+8,3%" trend-type="positive" /><orizon-stat-card title="Usuários" value="284" description="92% ativos" /></div><orizon-tabs label="Detalhes da conta"><div class="orizon-tabs__list" role="tablist"><button class="orizon-tabs__tab" id="account-overview-tab" type="button" role="tab" aria-selected="true" aria-controls="account-overview">Visão geral</button><button class="orizon-tabs__tab" id="account-history-tab" type="button" role="tab" aria-selected="false" aria-controls="account-history" tabindex="-1">Histórico</button></div><div class="orizon-tabs__panel" id="account-overview" role="tabpanel" tabindex="0" aria-labelledby="account-overview-tab"><orizon-card title="Resumo da conta"><p>Expansão prevista para duas novas unidades no próximo trimestre.</p></orizon-card></div><div class="orizon-tabs__panel" id="account-history" role="tabpanel" tabindex="0" aria-labelledby="account-history-tab" hidden><p>Histórico comercial consolidado.</p></div></orizon-tabs><orizon-timeline label="Histórico da conta" compact><article data-timeline-item role="listitem"><span data-timeline-marker>✓</span><div data-timeline-card><time>Hoje</time><h3>Renovação aprovada</h3><p>Contrato renovado por 24 meses.</p></div></article><article data-timeline-item role="listitem"><span data-timeline-marker>↗</span><div data-timeline-card><time>15 jul</time><h3>Reunião executiva</h3><p>Plano de expansão apresentado.</p></div></article></orizon-timeline><orizon-activity-feed label="Atividades"><section data-activity-group><h3>Hoje</h3><article data-activity-item><span data-activity-avatar>AM</span><div><p>Ana atualizou o health score.</p><time>há 32 min</time></div></article></section></orizon-activity-feed></div></section></orizon-split-view>
<orizon-drawer id="account-notes" title="Anotações da conta"><orizon-textarea name="Note" label="Nova anotação" rows="6" /><orizon-button text="Registrar anotação" /></orizon-drawer></div>
