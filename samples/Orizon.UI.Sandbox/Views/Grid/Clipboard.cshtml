@{ViewData["Title"]="Grid Clipboard";var rows=Enumerable.Range(1,40).Select(i=>new{Id=i,Code=$"CELL-{i:000}",Description=$"Linha preparada para Excel {i}",Quantity=i,Amount=i*19.9m}).ToArray();}
