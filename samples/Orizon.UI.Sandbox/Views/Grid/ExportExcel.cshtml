@{ViewData["Title"]="Grid Export Excel";var rows=Enumerable.Range(1,250).Select(i=>new{Id=i,Code=$"EXP-{i:0000}",Description=$"Registro exportável {i}",Date=DateTime.Today.AddDays(-i),Amount=i*128.45m,Quantity=i%100}).ToArray();}
