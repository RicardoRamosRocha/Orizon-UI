@{ViewData["Title"]="Grid Master Detail";var orders=Enumerable.Range(1,60).Select(i=>new{Id=i,Code=$"PED-{25000+i}",Customer=$"Cliente {i:000}",Status=new[]{"Novo","Faturado","Entregue"}[i%3],Amount=500m+i*87.4m,Notes=$"Pedido {i} possui itens, histórico e observações vinculadas."}).ToArray();}
<div class="component-catalog"><partial name="_GridHeader" model='@(("Master Detail", "Expanda cada pedido para renderizar um template com dados da linha."))'/><orizon-enterprise-grid items="orders" key-field="Id" label="Pedidos com detalhes" height="34rem" master-detail-template="&lt;article&gt;&lt;h3&gt;Detalhes de {{Code}}&lt;/h3&gt;&lt;p&gt;{{Notes}}&lt;/p&gt;&lt;strong&gt;Cliente: {{Customer}} · Total: {{Amount}}&lt;/strong&gt;&lt;/article&gt;"><orizon-grid-column field="Code" title="Pedido" width="170" /><orizon-grid-column field="Customer" title="Cliente" width="220" /><orizon-grid-column field="Status" title="Status" width="150" /><orizon-grid-column field="Amount" title="Total" width="160" format="currency" /></orizon-enterprise-grid></div>
