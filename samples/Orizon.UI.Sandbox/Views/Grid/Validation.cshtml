@{ViewData["Title"]="Grid Cell Validation";var rows=Enumerable.Range(1,30).Select(i=>new{Id=i,Sku=$"SKU-{i:0000}",Name=$"Item {i}",Email=$"contato{i}@@empresa.com",Quantity=i*3}).ToArray();}
