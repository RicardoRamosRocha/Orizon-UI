@{ViewData["Title"]="Grid Virtual Columns";var rows=Enumerable.Range(1,200).Select(row=>Enumerable.Range(1,300).ToDictionary(column=>$"C{column}",column=>(object)$"R{row}C{column}")).ToArray();}
<div class="component-catalog"><partial name="_GridHeader" model='@(("Virtual Columns", "300 colunas declaradas; somente a janela horizontal visível é renderizada."))'/><orizon-enterprise-grid id="virtual-columns-grid" items="rows" key-field="C1" label="Trezentas colunas" height="38rem" virtual-scroll virtual-columns><orizon-grid-toolbar search export />@for(var column=1;column<=300;column++){<orizon-grid-column field="@($"C{column}")" title="@($"Coluna {column}")" width="130" />}</orizon-enterprise-grid></div>
