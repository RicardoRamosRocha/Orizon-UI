@{
    var applicationName = ViewData["ApplicationName"]?.ToString() ?? "Orizon Platform";
}

<div class="orizon-sidebar-header">
    <a class="orizon-sidebar-brand"
       href="/"
       aria-label="@applicationName">

        <span class="orizon-sidebar-brand-mark"
              aria-hidden="true">
            O
        </span>

        <span class="orizon-sidebar-brand-content">
            <strong class="orizon-sidebar-brand-name">
                Orizon
            </strong>

            <span class="orizon-sidebar-brand-product">
                @applicationName
            </span>
        </span>
    </a>

    <button type="button"
            class="orizon-sidebar-collapse-button"
            data-sidebar-collapse
            aria-label="Recolher menu lateral"
            aria-expanded="true">

        <orizon-icon name="chevron-left" size="18" />
    </button>
</div>

<nav class="orizon-sidebar-navigation"
     aria-label="Menu administrativo">

    <div class="orizon-sidebar-section">
        <span class="orizon-sidebar-section-title">
            Geral
        </span>

        <a class="orizon-sidebar-link is-active"
           href="/Admin/Dashboard"
           aria-current="page">

            <orizon-icon name="house"
                         size="20"
                         class="orizon-sidebar-link-icon" />

            <span class="orizon-sidebar-link-label">
                Dashboard
            </span>
        </a>

        <a class="orizon-sidebar-link"
           href="/Admin/Notifications">

            <orizon-icon name="bell"
                         size="20"
                         class="orizon-sidebar-link-icon" />

            <span class="orizon-sidebar-link-label">
                Notificações
            </span>
        </a>
    </div>

    <div class="orizon-sidebar-section">
        <span class="orizon-sidebar-section-title">
            Gestão
        </span>

        <a class="orizon-sidebar-link"
           href="/Admin/Users">

            <orizon-icon name="users"
                         size="20"
                         class="orizon-sidebar-link-icon" />

            <span class="orizon-sidebar-link-label">
                Usuários
            </span>
        </a>

        <a class="orizon-sidebar-link"
           href="/Admin/Organization">

            <orizon-icon name="building"
                         size="20"
                         class="orizon-sidebar-link-icon" />

            <span class="orizon-sidebar-link-label">
                Organização
            </span>
        </a>

        <a class="orizon-sidebar-link"
           href="/Admin/Appearance">

            <orizon-icon name="gear"
                         size="20"
                         class="orizon-sidebar-link-icon" />

            <span class="orizon-sidebar-link-label">
                Aparência
            </span>
        </a>
    </div>
</nav>

<div class="orizon-sidebar-footer">
    <div class="orizon-sidebar-user">
        <span class="orizon-sidebar-user-avatar"
              aria-hidden="true">
            OR
        </span>

        <div class="orizon-sidebar-user-content">
            <strong class="orizon-sidebar-user-name">
                Usuário Orizon
            </strong>

            <span class="orizon-sidebar-user-role">
                Administrador
            </span>
        </div>
    </div>
</div>
