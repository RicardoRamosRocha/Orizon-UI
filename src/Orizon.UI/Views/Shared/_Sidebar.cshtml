@{
    var applicationName = ViewData["ApplicationName"]?.ToString() ?? "Orizon Platform";
    var currentPath = Context.Request.Path.Value?.TrimEnd('/').ToLowerInvariant() ?? "";
    bool IsCurrent(string path) => currentPath == path.ToLowerInvariant();
}

<div class="orizon-sidebar-header">
    <a class="orizon-sidebar-brand" href="/" aria-label="@applicationName">
        <span class="orizon-sidebar-brand-mark" aria-hidden="true">O</span>
        <span class="orizon-sidebar-brand-content">
            <strong class="orizon-sidebar-brand-name">Orizon UI</strong>
            <span class="orizon-sidebar-brand-product">Enterprise Design System</span>
        </span>
    </a>

    <button type="button"
            class="orizon-sidebar-collapse-button"
            data-sidebar-collapse
            aria-label="Recolher menu lateral"
            aria-expanded="true">
        <orizon-icon name="chevron-left" size="16" />
    </button>
</div>

<nav class="orizon-sidebar-navigation" aria-label="Menu administrativo">
    <div class="orizon-sidebar-section">
        <span class="orizon-sidebar-section-title">Visão geral</span>

        <a class="orizon-sidebar-link @(IsCurrent("/admin/dashboard") ? "is-active" : null)"
           href="/Admin/Dashboard"
           aria-current="@(IsCurrent("/admin/dashboard") ? "page" : null)"
           title="Dashboard">
            <orizon-icon name="house" size="19" class="orizon-sidebar-link-icon" />
            <span class="orizon-sidebar-link-label">Dashboard</span>
        </a>

        <a class="orizon-sidebar-link @(IsCurrent("/admin/notifications") ? "is-active" : null)"
           href="/Admin/Notifications"
           aria-current="@(IsCurrent("/admin/notifications") ? "page" : null)"
           title="Notificações">
            <orizon-icon name="bell" size="19" class="orizon-sidebar-link-icon" />
            <span class="orizon-sidebar-link-label">Notificações</span>
        </a>
    </div>

    <div class="orizon-sidebar-section">
        <span class="orizon-sidebar-section-title">Administração</span>

        <a class="orizon-sidebar-link @(IsCurrent("/admin/users") ? "is-active" : null)"
           href="/Admin/Users"
           aria-current="@(IsCurrent("/admin/users") ? "page" : null)"
           title="Usuários">
            <orizon-icon name="users" size="19" class="orizon-sidebar-link-icon" />
            <span class="orizon-sidebar-link-label">Usuários</span>
        </a>

        <a class="orizon-sidebar-link @(IsCurrent("/admin/organization") ? "is-active" : null)"
           href="/Admin/Organization"
           aria-current="@(IsCurrent("/admin/organization") ? "page" : null)"
           title="Organização">
            <orizon-icon name="building" size="19" class="orizon-sidebar-link-icon" />
            <span class="orizon-sidebar-link-label">Organização</span>
        </a>

        <a class="orizon-sidebar-link @(IsCurrent("/admin/appearance") ? "is-active" : null)"
           href="/Admin/Appearance"
           aria-current="@(IsCurrent("/admin/appearance") ? "page" : null)"
           title="Aparência">
            <orizon-icon name="gear" size="19" class="orizon-sidebar-link-icon" />
            <span class="orizon-sidebar-link-label">Aparência</span>
        </a>
    </div>

    <div class="orizon-sidebar-section">
        <span class="orizon-sidebar-section-title">Enterprise Grid</span>
        @foreach (var item in new[] {
            ("Basic Grid", "/grid"), ("Server Mode", "/grid/server-mode"), ("Server Sorting", "/grid/server-sorting"),
            ("Server Filtering", "/grid/server-filtering"), ("Server Grouping", "/grid/server-grouping"), ("Server Paging", "/grid/server-paging"),
            ("Infinite Scroll", "/grid/infinite-scroll"), ("Virtual Columns", "/grid/virtual-columns"), ("Tree Data", "/grid/tree-data"),
            ("Master Detail", "/grid/master-detail"), ("Batch Editing", "/grid/batch-editing"), ("Cell Validation", "/grid/validation"),
            ("Clipboard", "/grid/clipboard"), ("Export Excel", "/grid/export-excel"), ("Benchmark", "/grid/benchmark") })
        {
            var active = IsCurrent(item.Item2);
            <a class="orizon-sidebar-link @(active ? "is-active" : null)"
               href="@item.Item2"
               aria-current="@(active ? "page" : null)"
               title="@item.Item1">
                <orizon-icon name="table" size="19" class="orizon-sidebar-link-icon" />
                <span class="orizon-sidebar-link-label">@item.Item1</span>
            </a>
        }
    </div>
</nav>

<div class="orizon-sidebar-footer">
    <div class="orizon-sidebar-user">
        <span class="orizon-sidebar-user-avatar" aria-hidden="true">OR</span>
        <div class="orizon-sidebar-user-content">
            <strong class="orizon-sidebar-user-name">Usuário Orizon</strong>
            <span class="orizon-sidebar-user-role">Administrador</span>
        </div>
    </div>
</div>
